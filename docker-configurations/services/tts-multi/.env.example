# Multi-Model TTS Service Environment Configuration

# Gateway Port (main entry point)
TTS_GATEWAY_PORT=8196

# GPU Device IDs (0 or 1, adjust based on your setup)
KOKORO_GPU_ID=1
TADA_GPU_ID=1
QWEN_GPU_ID=1

# Models Path
MODELS_PATH=./models

# Model Preloading
PRELOAD_MODEL=true

# Idle Timeout (seconds) - models unload after idle period
IDLE_TIMEOUT=1200

# Timezone
TZ=Europe/Paris
