# FishAudio S2-Pro TTS Service Configuration
# Copy to .env and adjust values

# GPU assignment (1 = RTX 3090 24GB)
FISHAUDIO_GPU_ID=1

# Host port
FISHAUDIO_PORT=8197

# Model checkpoints directory (downloaded from HuggingFace on first run)
CHECKPOINTS_PATH=./checkpoints

# Reference audio files for voice cloning
REFERENCES_PATH=./references

# HuggingFace token (for gated model download)
HUGGINGFACE_TOKEN=

# Timezone
TZ=Europe/Paris
