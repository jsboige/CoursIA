# SPASS (Modal Logic Prover) - binaires Windows + documentation
!MyIA.AI.Notebooks/SymbolicAI/Tweety/ext_tools/spass/SPASS.exe
!MyIA.AI.Notebooks/SymbolicAI/Tweety/ext_tools/spass/SPASS-3.0/
# Mais exclure l'installeur inutile
MyIA.AI.Notebooks/SymbolicAI/Tweety/ext_tools/spass/SPASS_installer.exe

# EProver (FOL theorem prover) - installation complète partagée
!MyIA.AI.Notebooks/SymbolicAI/ext_tools/EProver/

# Scripts Python helpers (code source)
!MyIA.AI.Notebooks/SymbolicAI/ext_tools/*.py

# Bibliothèques natives SAT (Minisat, Lingeling, Picosat)
!MyIA.AI.Notebooks/SymbolicAI/Tweety/libs/native/

