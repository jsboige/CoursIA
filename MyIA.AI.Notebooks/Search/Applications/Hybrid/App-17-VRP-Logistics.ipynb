   "source": [
    "def solve_vrp_ortools(vrp_instance: VRPInstance, time_limit: int = 30) -> Optional[Dict]:\n",
    "    \"\"\"Resout le VRP avec OR-Tools.\"\"\"\n",
    "    \n",
    "    # Create routing index manager\n",
    "    manager = pywrap.RoutingIndexManager(\n",
    "        len(vrp_instance.distance_matrix),\n",
    "        num_vehicles=len(vrp_instance.vehicles),\n",
    "        depot_starts=[d.location for d in vrp_instance.depots]\n",
    "        vehicle_capacities=[v.capacity for v in vrp_instance.vehicles]\n",
    "        demands=vrp_instance.demands\n",
    "    )\n",
    "    \n",
    "    # Set up routing parameters\n",
    "    routing_parameters = pywrap.DefaultRoutingParameters()\n",
    "    routing_parameters.time_limit.seconds = time_limit\n",
    "    \n",
    "    # Solve\n",
    "    solution = manager.solve(routing_parameters)\n",
    "    \n",
    "    return solution"
   ]
