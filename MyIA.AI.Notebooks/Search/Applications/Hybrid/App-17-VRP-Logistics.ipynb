   "source": [
    "def benchmark_methods(vrp: VRPInstance, iterations: int = 3):\n",
    "    \"\"\"Compare les differentes methodes sur le probleme VRP.\"\"\"\n",
    "    results = {'OR-Tools': [], 'SA': [], 'GA': [], 'ACO': []}\n",
    "    \n",
    "    for i in range(iterations):\n",
    "        print(f\"\\n=== Iteration {i+1}/{iterations} ===\")\n",
    "        \n",
    "        # OR-Tools\n",
    "        start = time.time()\n",
    "        solution = solve_vrp_ortools(vrp, time_limit=10)\n",
    "        ortools_time = time.time() - start\n",
    "        ortools_dist = solution.objective_value() if solution else else float('inf')\n",
    "        results['OR-Tools'].append({'time': ortools_time, 'distance': ortools_dist})\n",
    "        \n",
    "        # SA\n",
    "        sa = SimulatedAnnealingVRP(vrp)\n",
    "        start = time.time()\n",
    "        result = sa.solve(iterations=200)\n",
    "        sa_time = time.time() - start\n",
    "        results['SA'].append({'time': sa_time, 'distance': result['distance']})\n",
    "        \n",
    "        # GA\n",
    "        ga = GeneticVRP(vrp)\n",
    "        start = time.time()\n",
    "        result = ga.solve()\n",
    "        ga_time = time.time() - start\n",
    "        results['GA'].append({'time': ga_time, 'distance': result['distance']})\n",
    "        \n",
    "        # ACO\n",
    "        aco = AntColonyVRP(vrp)\n",
    "        start = time.time()\n",
    "        result = aco.solve()\n",
    "        aco_time = time.time() - start\n",
    "        results['ACO'].append({'time': aco_time, 'distance': result['distance']})\n",
    "    \n",
    "    return results\n",
    "\n",
    "\n",
    "# Benchmark\n",
    "print(\"Benchmark des methodes...\")\n",
    "benchmark_results = benchmark_methods(vrp, iterations=3)\n",
    "\n",
    "# Resume\n",
    "print(\"\\n=== Resume ===\")\n",
    "for method, times in benchmark_results.items():\n",
    "    distances = [r['distance'] for r in times]\n",
    "    times_list = [r['time'] for r in times]\n",
    "    print(f\"{method}:\")\n",
    "    print(f\"  Distance moyenne: {np.mean(distances)::.2f} km\")\n",
    "    print(f\"  Temps moyen: {np.mean(times_list):.2f} s\")"
   }
