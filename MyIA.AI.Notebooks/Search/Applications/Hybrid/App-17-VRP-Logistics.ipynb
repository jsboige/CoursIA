    "## 1. Modelisation du Probleme\n",
    "\n",
    "### Definition du VRP\n",
    "\n",
    "| Element | Description |\n",
    "|---------|-------------|\n",
    "| **Clients** | Points de livraison (lat, lon) |\n",
    "| **Depot** | Points de depart (lat, lon) |\n",
    "| **Vehicules** | Flotte avec capacite (max N, |\n",
    "| **Demandes** | Demandes par client (d_i) |\n",
    "| **Contraintes** | Voir ci-dessous |"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "@dataclass\n",
    "class VRPInstance:\n",
    "    \"\"\"Instance du probleme VRP.\"\"\"\n",
    "    clients: List[Tuple[float, float]]  # (lat, lon)\n",
    "    depot: Tuple[float, float]\",
    "    vehicles: List[int]  # Capacite de vehicule\n",
    "    demands: List[int]  # Demand by client\n",
    "    distance_matrix: np.ndarray ",
    "    \n",
    "    def __post_init__(self):\n",
    "        self.distance_matrix = compute_distance_matrix()\n",
    "    \n",
    "    def compute_distance_matrix(self) -> np.ndarray:\n",
    "        \"\"\"Calcule la matrice des distances entre tous les points.\"\"\"\n",
    "        n_clients = len(self.clients)\n",
    "        n_depots = len(self.depots)\n",
    "        n_vehicles = len(self.vehicles)\n",
    "        \n",
    "        # Matrice distance client-depot\n",
    "        for i in range(n_clients):\n",
    "            for j in range(n_depots):\n",
    "                d = euclidean_distance(\n",
    "                    self.clients[i], self.depots[j]\",
    "                )\n",
    "                # Distance depot-depot\n",
    "                for k in range(i+1, n_depots):\n",
    "                    if k < j:\n",
    "                        d2 = euclidean_distance(\n",
    "                            self.depots[i], self.depots[k]\",
    "                            self.distance_matrix[i, j] = d2\n",
    "                            self.distance_matrix[j, i] = d2\n",
    "                    else:\n",
    "                        d2 = np.sqrt((dx1 - dx2)**2 + (dy2 - dy1)**2)\n",
    "                        self.distance_matrix[i, j] = d2\n",
    "                    else:\n",
    "                        self.distance_matrix[i, j] = d1\n",
    "        return self.distance_matrix\n",
    "    \n",
    "    def get_distance(self, client1: Tuple[float, float], client2: Tuple[float, float]) -> float:\n",
    "        \"\"\"Retourne la distance entre deux points.\"\"\"\n",
    "        return self.distance_matrix[client1.id][client2.id]\n",
    "    \n",
    "    def get_total_demand(self) -> int:\n",
    "        \"\"\"Calcule la demande totale de tous les clients.\"\"\"\n",
    "        total = 0\n",
    "        for client in self.clients:\n",
    "            for depot in self.depots:\n",
    "                # Demande du depot (chaque vehicule peut livrer)\n",
    "                total += d\n",
    "        return total\n",
    "    \n",
    "    def get_depot_for_vehicle(self, vehicle_id: int) -> Tuple[float, float]::\n",
    "        \"\"\"Retourne le depot par ID.\"\"\"\n",
    "        for depot in self.depots:\n",
    "            if depot.id == vehicle_id:\n",
    "                return depot.location\n",
    "        return None\n",
    "\n",
    "    def get_clients_served_by_depot(self, depot_id: int) -> List[int]:\n",
    "        \"\"\"Retourne la liste des clients servis par un depot.\"\"\"\n",
    "        return [c for c in self.clients if self.depots[c].depot_id == depot_id]\n",
    "    \n",
    "def create_sample_instance() -> VRPInstance:\n",
    "    \"\"\"Cree un exemple de probleme VRP.\"\"\"\n",
    "    # Clients: Paris (48.8566, 2.3522),\n",
    "               Lyon (45.7640, 4.8357),\n",
    "               Marseille (43.2965, 5.3698),\n",
    "               Bordeaux (44.8378, -0.5792),\n",
    "               Lille (50.6292, 3.0573),\n",
    "               Nantes (47.2184, -1.5536),\n",
    "               Nice (43.7102, 7.2620),\n",
    "               Toulouse (43.6047, 1.4442),\n",
    "    # Depots\n",
    "    depots = [\n",
    "        Depot(0, (48.8566, 2.3522), 10),  # Paris\n",
    "        Depot(1, (45.7640, 4.8357), 15),  # Lyon\n",
    "        Depot(2, (43.2965, 5.3698), 20),  # Marseille\n",
    "        Depot(3, (44.8378, -0.5792), 12),  # Bordeaux\n",
    "        Depot(4, (50.6292, 3.0573), 8),  # Lille\n",
    "        Depot(5, (47.2184, -1.5536), 25),  # Nantes\n",
    "        Depot(6, (43.7102, 7.2620), 18),  # Nice\n",
    "        Depot(7, (43.6047, 1.4442), 22),  # Toulouse\n",
    "    ]\n",
    "    # Vehicles\n",
    "    vehicles = [1, 2, 3, 4, 5, 6, 7, 8]\n",
    "    # Demands\n",
    "    demands = [\n",
    "        30, 25, 20, 15,  # Client 0\n",
    "        25, 20, 15, 35,  # Client 1\n",
    "        40, 30, 20, 25,  # Client 2\n",
    "        35, 25, 20, 30,  # Client 3\n",
    "        45, 35, 25, 40,  # Client 4\n",
    "        30, 20, 15, 20,  # Client 5\n",
    "        50, 40, 30, 45,  # Client 6\n",
    "        20, 15, 10  25,  # Client 7\n",
    "        55, 45, 35, 50,  # Client 8\n",
    "    ]\n",
    "    return VRPInstance(clients, depots, vehicles, demands)"
   }
