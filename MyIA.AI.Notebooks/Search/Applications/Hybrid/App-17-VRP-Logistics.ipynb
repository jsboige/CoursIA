    "## 4. Metaheuristique: Algorithme Genetique\n",
    "\n",
    "L'algorithme genetique utilise une population de routes qui evoluent vers une meilleure solution."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class GeneticVRP:\n",
    "    \"\"\"Algorithme genetique pour le VRP.\"\"\"\n",
    "    \n",
    "    def __init__(self, vrp: VRPInstance, population_size: int = 50, \n",
    "                 mutation_rate: float = 0.2, generations: int = 100):\n",
    "        self.vrp = vrp\n",
    "        self.pop_size = population_size\n",
    "        self.mutation_rate = mutation_rate\n",
    "        self.generations = generations\n",
    "        self.best_solution = None\n",
    "        self.best_distance = float('inf')\n",
    "    \n",
    "    def create_individual(self) -> List[List[int]]:\n",
    "        \"\"\"Cree un individu (solution initiale).\"\"\"\n",
    "        return [route[:] for route in self.initial_solution()]\n",
    "    \n",
    "    def fitness(self, individual: List[List[int]]) -> float:\n",
    "        \"\"\"Calcule le fitness (inverse de la distance).\"\"\"\n",
    "        return self.calculate_distance(individual)\n",
    "    \n",
    "    def select(self, population: List[List[List[int]]]) -> List[List[List[int]]]:\n",
    "        \"\"\"Selection par tournoi.\"\"\"\n",
    "        # Trier par fitness\n",
    "        sorted_pop = sorted(population, key=lambda x: self.fitness(x))\n",
    "        \n",
    "        # Selection des meilleurs\n",
    "        selected = []\n",
    "        for i in range(self.pop_size):\n",
    "            selected.append(sorted_pop[i])\n",
    "        \n",
    "        return selected\n",
    "    \n",
    "    def crossover(self, parent1: List[List[int]], parent2: List[List[int]]) -> List[List[int]]:\n",
    "        \"\"\"Crossover entre deux parents.\"\"\"\n",
    "        child = []\n",
    "        \n",
    "        for v_idx in range(len(parent1)):\n",
    "            # Point de crossover aleatoire\n",
    "            if random.random() < 0.5:\n",
    "                child.append(parent1[v_idx][:])\n",
    "            else:\n",
    "                child.append(parent2[v_idx][:])\n",
    "        \n",
    "        return child\n",
    "    \n",
    "    def mutate(self, individual: List[List[int]]) -> List[List[int]]:\n",
    "        \"\"\"Mutation: reorganiser une route.\"\"\"\n",
    "        mutated = [route[:] for route in individual]\n",
    "        \n",
    "        if random.random() < self.mutation_rate:\n",
    "            # Choisir un vehicule aleatoire\n",
    "            v_idx = random.randint(0, len(mutated) - 1)\n",
    "            if mutated[v_idx] and len(mutated[v_idx]) > 1:\n",
    "                # Inverser une partie de la route\n",
    "                route = mutated[v_idx]\n",
    "                split_point = random.randint(1, len(route) - 1)\n",
    "                mutated[v_idx] = route[:split_point] + route[split_point:]\n",
    "        \n",
    "        return mutated\n",
    "    \n",
    "    def solve(self) -> Optional[Dict]:\n",
    "        \"\"\"Execute l'algorithme genetique.\"\"\"\n",
    "        population = [self.create_individual() for _ in range(self.pop_size)]\n",
    "        \n",
    "        for gen in range(self.generations):\n",
    "            # Selection\n",
    "            selected = self.select(population)\n",
    "            \n",
    "            # Crossover\n",
    "            new_population = []\n",
    "            for i in range(0, len(selected), 2):\n",
    "                parent1 = selected[i]\n",
    "                parent2 = selected[i + 1]\n",
    "                child = self.crossover(parent1, parent2)\n",
    "                new_population.append(child)\n",
    "            \n",
    "            # Mutation\n",
    "            for i in range(len(new_population)):\n",
    "                new_population[i] = self.mutate(new_population[i])\n",
    "            \n",
    "            population = new_population\n",
    "            \n",
    "            # Meilleur solution\n",
    "            for individual in population:\n",
    "                distance = self.fitness(individual)\n",
    "                if distance < self.best_distance:\n",
    "                    self.best_distance = distance\n",
    "                    self.best_solution = individual\n",
    "        \n",
    "        return {\n",
    "            'solution': self.best_solution,\n",
    "            'distance': self.best_distance\n",
    "        }\n",
    "\n",
    "\n",
    "# Test GA\n",
    "ga_vrp = GeneticVRP(vrp, population_size=20, mutation_rate=0.1, generations=50)\n",
    "result = ga_vrp.solve()\n",
    "\n",
    "print(f\"\\nAlgorithme Genetique:\")\n",
    "print(f\"Distance finale: {result['distance']:.2f} km\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Metaheuristique: Ant Colony Optimization (ACO)\n",
    "\n",
    "ACO s'inspire des colonies de fourmis cherchant les meilleures routes base sur les pheromones."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class AntColonyVRP:\n",
    "    \"\"\"Ant Colony Optimization pour le VRP.\"\"\"\n",
    "    \n",
    "    def __init__(self, vrp: VRPInstance, n_ants: int = 20, \n",
    "                 n_iterations: int = 100, evaporation: float = 0.5):\n",
    "        self.vrp = vrp\n",
    "        self.n_ants = n_ants\n",
    "        self.n_iterations = n_iterations\n",
    "        self.evaporation = evaporation\n",
    "        self.pheromones = np.ones((len(vrp.clients), len(vrp.clients)))\n",
    "        self.best_solution = None\n",
    "        self.best_distance = float('inf')\n",
    "    \n",
    "    def construct_solution(self) -> List[int]:\n",
    "        \"\"\"Construit une solution basee sur les pheromones.\"\"\"\n",
    "        solution = [[] for _ in self.vrp.vehicles]\n",
    "        unvisited = list(range(len(self.vrp.clients)))\n",
    "        \n",
    "        for v_idx in range(len(self.vrp.vehicles)):\n",
    "            route = []\",
    "            current_load = 0\n",
    "            current_loc = self.vrp.depots[v_idx].id\n",
    "            capacity = self.vrp.vehicles[v_idx].capacity\n",
    "            \n",
    "            while unvisited and current_load < capacity:\n",
    "                # Choisir le prochain client (probabilite proportionnelle aux pheromones)\n",
    "                probabilities = []\",
    "                candidates = []\n",
    "                \n",
    "                for client_id in unvisited:\n",
    "                    if current_load + self.vrp.demands[client_id] <= capacity:\n",
    "                        pheromone = self.pheromones[current_loc][client_id]\n",
    "                        distance = self.vrp.distance_matrix[current_loc][client_id]\n",
    "                        # Heuristique: inverse de la distance\n",
    "                        heuristic = 1.0 / (distance + 1e-6)\n",
    "                        probabilities.append(pheromone * heuristic)\n",
    "                        candidates.append(client_id)\n",
    "                \n",
    "                if not candidates:\n",
    "                    break\n",
    "                \n",
    "                # Selection par roulette\n",
    "                total = sum(probabilities)\n",
    "                r = random.uniform(0, total)\n",
    "                cumsum = 0\n",
    "                selected = candidates[-1]\n",
    "                \n",
    "                for i, p in enumerate(probabilities):\n",
    "                    cumsum += p\n",
    "                    if r <= cumsum:\n",
    "                        selected = candidates[i]\n",
    "                        break\n",
    "                \n",
    "                route.append(selected)\n",
    "                unvisited.remove(selected)\n",
    "                current_load += self.vrp.demands[selected]\n",
    "                current_loc = selected\n",
    "            \n",
    "            solution[v_idx] = route\n",
    "        \n",
    "        return solution\n",
    "    \n",
    "    def calculate_distance(self, solution: List[List[int]]) -> float:\n",
    "        \"\"\"Calcule la distance totale.\"\"\"\n",
    "        total = 0\n",
    "        for v_idx in range(len(self.vrp.vehicles)):\n",
    "            route = solution[v_idx]\n",
    "            if not route:\n",
    "                continue\n",
    "            \n",
    "            depot = self.vrp.depots[v_idx]\n",
    "            total += self.vrp.distance_matrix[depot.id][route[0]]\n",
    "            \n",
    "            for i in range(len(route) - 1):\n",
    "                total += self.vrp.distance_matrix[route[i]][route[i + 1]]\n",
    "            \n",
    "            total += self.vrp.distance_matrix[route[-1]][depot.id]\n",
    "        \n",
    "        return total\n",
    "    \n",
    "    def update_pheromones(self, solution: List[List[int]], distance: float):\n",
    "        \"\"\"Met a jour les pheromones.\"\"\"\n",
    "        # Evaporation\n",
    "        self.pheromones *= (1 - self.evaporation)\n",
    "        \n",
    "        # Deposition\n",
    "        deposit = 1.0 / distance\n",
    "        \n",
    "        for v_idx in range(len(self.vrp.vehicles)):\n",
    "            route = solution[v_idx]\n",
    "            if not route:\n",
    "                continue\n",
    "            \n",
    "            depot = self.vrp.depots[v_idx]\n",
    "            self.pheromones[depot.id][route[0]] += deposit\n",
    "            \n",
    "            for i in range(len(route) - 1):\n",
    "                self.pheromones[route[i]][route[i + 1]] += deposit\n",
    "    \n",
    "    def solve(self) -> Optional[Dict]:\n",
    "        \"\"\"Execute l'algorithme ACO.\"\"\"\n",
    "        for iteration in range(self.n_iterations):\n",
    "            solutions = []\n",
    "            distances = []\n",
    "            \n",
    "            for ant in range(self.n_ants):\n",
    "                solution = self.construct_solution()\n",
    "                distance = self.calculate_distance(solution)\n",
    "                solutions.append(solution)\n",
    "                distances.append(distance)\n",
    "                \n",
    "                if distance < self.best_distance:\n",
    "                    self.best_distance = distance\n",
    "                    self.best_solution = solution\n",
    "            \n",
    "            # Mettre a jour les pheromones avec la meilleure solution\n",
    "            self.update_pheromones(self.best_solution, self.best_distance)\n",
    "        \n",
    "        return {\n",
    "            'solution': self.best_solution,\n",
    "            'distance': self.best_distance\n",
    "        }\n",
    "\n",
    "\n",
    "# Test ACO\n",
    "aco_vrp = AntColonyVRP(vrp, n_ants=15, n_iterations=50)\n",
    "result = aco_vrp.solve()\n",
    "\n",
    "print(f\"\\nAnt Colony Optimization:\")\n",
    "print(f\"Distance finale: {result['distance']:.2f} km\")"
   ]
  },
