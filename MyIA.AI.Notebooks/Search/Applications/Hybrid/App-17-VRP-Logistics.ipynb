    "## 3. Metaheuristique: Recuit Simule (SA)\n",
    "\n",
    "Le recuit simule est une metaheuristique d'inspiration naturelle (recuit de fourmis qui cherchent la meilleure solution)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class SimulatedAnnealingVRP:\n",
    "    \"\"\"Recuit simule pour le VRP.\"\"\"\n",
    "    \n",
    "    def __init__(self, vrp: VRPInstance, initial_temp: float = 100.0, \n",
    "                 cooling_rate: float = 0.995):\n",
    "        self.vrp = vrp\n",
    "        self.temp = initial_temp\n",
    "        self.cooling_rate = cooling_rate\n",
    "        self.best_solution = None\n",
    "        self.best_distance = float('inf')\n",
    "        self.history = []\n",
    "    \n",
    "    def initial_solution(self) -> List[List[int]]:\n",
    "        \"\"\"Genere une solution initiale (chaque vehicule sert au client le plus proche).\"\"\"\n",
    "        solution = [[] for _ in self.vrp.vehicles]\n",
    "        unassigned = list(range(len(self.vrp.clients)))\n",
    "        \n",
    "        for v_idx in range(len(self.vrp.vehicles)):\n",
    "            capacity = self.vrp.vehicles[v_idx].capacity\n",
    "            current_load = 0\n",
    "            route = []\n",
    "            \n",
    "            # Assigner les clients les plus proches\n",
    "            while unassigned and current_load < capacity:\n",
    "                # Trouver le client non assigne le plus proche\n",
    "                best_client = None\n",
    "                best_increase = float('inf')\n",
    "                \n",
    "                for client_id in unassigned:\n",
    "                    # Calculer le cout d'ajout (distance depuis le dernier point)\n",
    "                    if route:\n",
    "                        last_depot = self.vrp.depots[v_idx]\n",
    "                        dist = self.vrp.distance_matrix[last_depot.id][client_id]\n",
    "                    else:\n",
    "                        # Distance depuis le depot\n",
    "                        depot = self.vrp.depots[v_idx]\n",
    "                        dist = self.vrp.distance_matrix[depot.id][client_id]\n",
    "                    \n",
    "                    if dist < best_increase:\n",
    "                        best_increase = dist\n",
    "                        best_client = client_id\n",
    "                \n",
    "                if best_client is not None:\n",
    "                    # Verifier la capacite\n",
    "                    demand = self.vrp.demands[best_client]\n",
    "                    if current_load + demand <= capacity:\n",
    "                        route.append(best_client)\n",
    "                        unassigned.remove(best_client)\n",
    "                        current_load += demand\n",
    "                    else:\n",
    "                        break\n",
    "                else:\n",
    "                    break\n",
    "            \n",
    "            solution[v_idx] = route\n",
    "        \n",
    "        return solution\n",
    "    \n",
    "    def calculate_distance(self, solution: List[List[int]]) -> float:\n",
    "        \"\"\"Calcule la distance totale d'une solution.\"\"\"\n",
    "        total = 0\n",
    "        for v_idx, range(len(self.vrp.vehicles)):\n",
    "            route = solution[v_idx]\n",
    "            if not route:\n",
    "                continue\n",
    "            \n",
    "            # Distance depot -> premier client\n",
    "            depot = self.vrp.depots[v_idx]\n",
    "            first_client = route[0]\n",
    "            total += self.vrp.distance_matrix[depot.id][first_client]\n",
    "            \n",
    "            # Distances entre clients\n",
    "            for i in range(len(route) - 1):\n",
    "                from_client = route[i]\n",
    "                to_client = route[i + 1]\n",
    "                total += self.vrp.distance_matrix[from_client][to_client]\n",
    "            \n",
    "            # Retour au depot\n",
    "            last_client = route[-1]\n",
    "            total += self.vrp.distance_matrix[last_client][depot.id]\n",
    "        \n",
    "        return total\n",
    "    \n",
    "    def get_neighbor(self, solution: List[List[int]]) -> List[List[int]]:\n",
    "        \"\"\"Genere un voisin par echange de deux clients.\"\"\"\n",
    "        neighbor = [route[:] for route in solution]\n",
    "        \n",
    "        # Choisir deux vehicules differents\n",
    "        if len(self.vrp.vehicles) < 2:\n",
    "            return neighbor\n",
    "        \n",
    "        v1, v2 = random.sample(range(len(self.vrp.vehicles)), 2)\n",
    "        if v1 == v2:\n",
    "            v2 = (v2 + 1) % len(self.vrp.vehicles)\n",
    "        \n",
    "        # Choisir un client dans chaque route\n",
    "        if neighbor[v1] and neighbor[v2]:\n",
    "            c1 = random.randint(0, len(neighbor[v1]))\n",
    "            c2 = random.randint(0, len(neighbor[v2]))\n",
    "            \n",
    "            # Echanger\n",
    "            neighbor[v1][c1], neighbor[v2][c2] = neighbor[v2][c2], neighbor[v1][c1]\n",
    "        \n",
    "        return neighbor\n",
    "    \n",
    "    def is_valid(self, solution: List[List[int]]) -> bool:\n",
    "        \"\"\"Verifie si une solution est valide (capacite respectee).\"\"\"\n",
    "        for v_idx in range(len(self.vrp.vehicles)):\n",
    "            route = solution[v_idx]\n",
    "            total_demand = sum(self.vrp.demands[c] for c in route)\n",
    "            if total_demand > self.vrp.vehicles[v_idx].capacity:\n",
    "                return False\n",
    "        \n",
    "        # Verifier que tous les clients sont servis\n",
    "        all_served = set()\n",
    "        for route in solution:\n",
    "            all_served.update(route)\n",
    "        \n",
    "        return len(all_served) == len(self.vrp.clients)\n",
    "    \n",
    "    def solve(self, iterations: int = 1000) -> Optional[Dict]:\n",
    "        \"\"\"Execute l'algorithme SA.\"\"\"\n",
    "        current = self.initial_solution()\n",
    "        self.best_solution = current\n",
    "        self.best_distance = self.calculate_distance(current)\n",
    "        \n",
    "        for i in range(iterations):\n",
    "            # Generer un voisin\n",
    "            neighbor = self.get_neighbor(current)\n",
    "            \n",
    "            # Calculer la distance\n",
    "            neighbor_distance = self.calculate_distance(neighbor)\n",
    "            \n",
    "            # Critere d'acceptation\n",
    "            delta = neighbor_distance - self.best_distance\n",
    "            probability = np.exp(-delta / self.temp)\n",
    "            \n",
    "            if random.random() < probability or self.is_valid(neighbor):\n",
    "                current = neighbor\n",
    "                if neighbor_distance < self.best_distance:\n",
    "                    self.best_solution = neighbor\n",
    "                    self.best_distance = neighbor_distance\n",
    "            \n",
    "            # Refroidissement\n",
    "            self.temp *= self.cooling_rate\n",
    "            self.history.append(self.best_distance)\n",
    "        \n",
    "        return {\n",
    "            'solution': self.best_solution,\n",
    "            'distance': self.best_distance,\n",
    "            'history': self.history\n",
    "        }\n",
    "\n",
    "\n",
    "# Test SA\n",
    "sa_vrp = SimulatedAnnealingVRP(vrp, initial_temp=50, cooling_rate=0.99)\n",
    "result = sa_vrp.solve(iterations=500)\n",
    "\n",
    "print(f\"\\nSimulated Annealing:\")\n",
    "print(f\"Distance finale: {result['distance']:.2f} km\")\n",
    "print(f\"Amelioration: {result['distance'] / sa_vrp.best_distance:.2f} km\")"
   ]
  },
