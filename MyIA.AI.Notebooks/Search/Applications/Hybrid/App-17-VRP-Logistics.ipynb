    "# Visualisation\n",
    "def plot_comparison(benchmark_results: Dict):\n",
    "    \"\"\"Visualise la comparaison.\"\"\"\n",
    "    fig, axes = plt.subplots(1, 2, figsize=(12, 5))\n",
    "    \n",
    "    methods = list(benchmark_results.keys())\n",
    "    \n",
    "    # Distance\n",
    "    ax1 = axes[0]\n",
    "    distances = [np.mean([r['distance'] for r in benchmark_results[m]]) for m in methods]\n",
    "    ax1.bar(methods, distances, color=['blue', 'green', 'red', 'orange'])\n",
    "    ax1.set_ylabel('Distance moyenne (km)')\n",
    "    ax1.set_title('Qualite des solutions')\n",
    "    \n",
    "    # Temps\n",
    "    ax2 = axes[1]\n",
    "    times = [np.mean([r['time'] for r in benchmark_results[m]]) for m in methods]\n",
    "    ax2.bar(methods, times, color=['blue', 'green', 'red', 'orange'])\n",
    "    ax2.set_ylabel('Temps moyen (s)')\n",
    "    ax2.set_title('Temps d\\'execution')\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "plot_comparison(benchmark_results)"
   ]
