# ============================================================================
# Playwright E2E Tests - Open WebUI
# ============================================================================
#
# INSTRUCTIONS :
# 1. Copier ce fichier vers .env : cp .env.example .env
# 2. Remplacer les valeurs "your_..._here" par vos vraies credentials
# 3. Le fichier .env est automatiquement ignore par Git (securite)
#
# ============================================================================
# ETUDIANTS - CONFIGURATION RAPIDE
# ============================================================================
#
# Option A - Instance de cours (fournie par l'enseignant) :
#   1. cp .env.example .env
#   2. L'enseignant vous fournit l'URL et les credentials
#   3. Remplacer OWUI_URL, OWUI_EMAIL, OWUI_PASSWORD ci-dessous
#
# Option B - Instance locale (Docker) :
#   1. cp .env.example .env
#   2. Deployer Open WebUI avec : docker compose up -d
#   3. Mettre OWUI_URL=http://localhost:3000
#   4. Creer un compte admin sur votre instance locale
#
# ============================================================================

# ============================================================================
# SECTION 1 : Instance principale Open WebUI
# ============================================================================
# URL de l'instance Open WebUI a tester
OWUI_URL=https://open-webui.example.com

# Credentials de connexion (compte admin recommande pour les tests complets)
OWUI_EMAIL=your_email_here
OWUI_PASSWORD=your_password_here

# ============================================================================
# SECTION 2 : Instance secondaire (pour les tests multi-tenant - Module 05)
# ============================================================================
# Ces variables sont optionnelles - necessaires uniquement pour le module 05
#
# OWUI_TENANT2_URL=https://tenant2.open-webui.example.com
# OWUI_TENANT2_EMAIL=your_tenant2_email_here
# OWUI_TENANT2_PASSWORD=your_tenant2_password_here

# ============================================================================
# SECTION 3 : Modeles LLM disponibles
# ============================================================================
# Nom du modele cloud (OpenAI, Anthropic, etc.) pour les tests de chat
# Doit etre un modele rapide et disponible sur votre instance
OWUI_CLOUD_MODEL=gpt-5.1

# Nom du modele local (optionnel - pour les tests avec modele local/vLLM)
# Le nom doit correspondre exactement a ce qui apparait dans le selecteur de modeles
# OWUI_LOCAL_MODEL=Qwen3.5-35B-A3B (Fast)

# Nom d'un modele persona/custom (optionnel - pour les tests de personas)
# OWUI_PERSONA_MODEL=Expert Analyste

# ============================================================================
# SECTION 4 : Configuration Playwright
# ============================================================================
# Timeout global par test en millisecondes (defaut: 120000 = 2 min)
# Les reponses LLM peuvent etre lentes, surtout avec des modeles locaux
PLAYWRIGHT_TIMEOUT=120000

# Mode headless (true = sans fenetre navigateur visible)
# Mettre a false pour deboguer visuellement
PLAYWRIGHT_HEADLESS=true

# Navigateur a utiliser (chromium, firefox, webkit)
PLAYWRIGHT_BROWSER=chromium

# Locale du navigateur (fr-FR pour Open WebUI en francais)
PLAYWRIGHT_LOCALE=fr-FR
