# Claudish Environment Configuration
# Copy to claudish.env (or your .secrets/master.env entry) and fill in your values.
# NEVER commit real keys/tokens — placeholders only.

# === CLIENT-SIDE (what the assistant points to) ===
# Replace api.anthropic.com with your Claudish gateway
ANTHROPIC_BASE_URL=https://models.myia.io
ANTHROPIC_AUTH_TOKEN=
# Default tier/model: glm-5.2 (Sonnet->z.ai), claude-opus-4-8 (Opus->Anthropic),
# qwen3.6-35b-a3b (Haiku->Qwen vLLM). Or let the active profile choose the tier.
ANTHROPIC_MODEL=glm-5.2

# === PROVIDER CONCURRENCY CAPS (config.json, not env) ===
# Per-provider caps. Example: GLM Coding Plan tolerates ~8 parallel long streams;
# a single GPU (Qwen vLLM) saturates on 1 concurrent prefill of 120K tokens.
providerConcurrency={"glm-coding": 8, "vllm-myia": 1}

# === CUSTOM ENDPOINTS (config.json) ===
# Named endpoints, each with its own maxConcurrency.
# Example: self-hosted Qwen vLLM
customEndpoints={"vllm-myia@http://localhost:8000/v1": {"maxConcurrency": 1}}

# === WEB SEARCH INTERCEPTION (optional) ===
# Provider web_search calls are intercepted and served via SearXNG (graceful text fallback)
SEARXNG_URL=
SEARXNG_MCP_URL=

# === CAPTURE (debugging / offline repro, optional) ===
# When set, request bodies are captured to this dir for offline reproduction.
# Leave unset in production.
CLAUDISH_CAPTURE_DIR=
