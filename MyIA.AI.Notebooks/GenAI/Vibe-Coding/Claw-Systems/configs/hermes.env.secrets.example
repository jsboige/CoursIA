# hermes.env.secrets.example
#
# Template des secrets Hermes. Ce fichier est copie vers /opt/data/.env.secrets
# sur le volume persistant et charge par le script de restore au demarrage.
#
# RENOMMER en .env.secrets et remplir. NE JAMAIS committer le fichier rempli.
# Les valeurs ci-dessous sont des PLACEHOLDERS, pas des secrets reels.

# --- LLM (z.ai natif, GLM) ---
# Cle API du provider z.ai (endpoint natif /api/coding/paas/v4).
# NE PAS utiliser la couche de compat Anthropic (voir 06-Hermes-Deploy).
ZAI_API_KEY=<your-zai-api-key>

# --- Telegram ---
# Token du bot via @BotFather (https://t.me/BotFather).
TELEGRAM_BOT_TOKEN=<your-telegram-bot-token>

# --- GitHub (jobs pr-review, gh CLI) ---
# Personal Access Token (scope: repo, workflow si besoin).
GITHUB_TOKEN=<your-github-pat>

# --- Proxy MCP LAN ---
# Bearer auth du proxy MCP (port 9090). Communique a tous les serveurs MCP.
MCP_AUTH_TOKEN=<your-mcp-proxy-bearer>

# --- Cluster ASR (optionnel) ---
# STT self-hosted (Whisper). Laisser vide si non utilise.
WHISPER_BEARER_TOKEN=<your-whisper-bearer-or-blank>
