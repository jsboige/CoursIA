# NanoClaw Environment Configuration
# Copy to nanoclaw.env and fill in your values

# === TELEGRAM (required) ===
TELEGRAM_BOT_TOKEN=

# === LLM (required - choose one) ===
# Option A: OpenRouter (recommended for beginners)
OPENROUTER_API_KEY=
MODEL_NAME=openai/qwen3.6-35b-a3b

# Option B: Local LLM (Ollama, vLLM, etc.)
# LLM_BASE_URL=http://localhost:11434/v1
# MODEL_NAME=llama3
# OPENROUTER_API_KEY=not-needed

# === ASR (optional - for voice messages) ===
ASR_ENDPOINT=https://whisper-api.myia.io/v1/audio/transcriptions
ASR_API_KEY=

# === Agent Configuration ===
SYSTEM_PROMPT=Tu es NanoClaw, un assistant IA autonome.
MAX_TOKENS=4096
TEMPERATURE=0.7
LOG_LEVEL=info
