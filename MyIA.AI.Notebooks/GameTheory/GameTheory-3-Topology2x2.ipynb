    "# Transformer Prisoner's Dilemma en Stag Hunt\n",
    "pd = CLASSIC_GAMES[\"Prisoner's Dilemma\"]\n",
    "sh = CLASSIC_GAMES[\"Stag Hunt\"]\n",
    "\n",
    "path = find_swap_path(pd, sh)\n",
