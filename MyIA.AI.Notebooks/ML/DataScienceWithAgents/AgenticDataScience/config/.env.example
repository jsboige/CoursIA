# AgenticDataScience - Configuration Multi-Provider
# Copier ce fichier vers .env et configurer votre provider

# === PROVIDER ACTIF ===
# Options: gemini, openai, openrouter, vllm, lmstudio
ACTIVE_PROVIDER=gemini

# === GEMINI 3.1 (Recommandé production) ===
# Obtenir une clé: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.1-pro

# === OPENAI ===
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# === OPENROUTER (Accès multi-modèles) ===
# Utilise les mêmes variables OPENAI_*
#OPENAI_BASE_URL=https://openrouter.ai/api/v1
#OPENAI_MODEL=anthropic/claude-3.5-sonnet

# === vLLM via Reverse Proxy ===
# Configurez votre endpoint vLLM hébergé
VLLM_BASE_URL=https://your-vllm-endpoint.com/v1
VLLM_MODEL=Qwen/Qwen2.5-72B-Instruct
VLLM_API_KEY=  # Optionnel selon votre configuration

# === LM Studio (Local avec GUI) ===
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=local-model

# === GCP (Day 7 uniquement) ===
GOOGLE_GENAI_USE_VERTEXAI=0
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
