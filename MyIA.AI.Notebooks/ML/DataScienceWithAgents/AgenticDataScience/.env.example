# AgenticDataScience - Configuration Multi-Provider
# ============================================================

# Provider actif: gemini, openrouter, vllm, openai, lmstudio
ACTIVE_PROVIDER=vllm

# ============================================================
# Google Gemini 3.1 (Production)
# ============================================================
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.1-pro

# ============================================================
# OpenRouter (Acces multi-modeles)
# ============================================================
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4.1

# ============================================================
# vLLM via Reverse Proxy (Modele local heberge)
# ============================================================
VLLM_BASE_URL=https://your-vllm-endpoint.com/v1
VLLM_MODEL=qwen3.5-35b-a3b
VLLM_API_KEY=your-key-if-needed

# ============================================================
# OpenAI (Alternative directe)
# ============================================================
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ============================================================
# LM Studio (Local avec GUI - si utilise)
# ============================================================
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=local-model
