   },
   "source": [
    "### Entraînement et Évaluation du modèle"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "998fec65",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-02-26T07:41:17.410661Z",
