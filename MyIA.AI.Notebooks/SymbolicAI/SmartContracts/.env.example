# SmartContracts Series - Environment Configuration
# Copy to .env and fill in your values: cp .env.example .env

# ============================================================
# Blockchain RPC Endpoints
# ============================================================

# Ethereum Sepolia testnet - get free key at https://www.alchemy.com/
SEPOLIA_RPC=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Local anvil (started via WSL: wsl -- ~/.foundry/bin/anvil --host 0.0.0.0)
ANVIL_RPC=http://127.0.0.1:8545

# Mainnet L2s (public RPCs, no key needed)
BASE_RPC=https://mainnet.base.org
POLYGON_RPC=https://polygon-rpc.com

# ============================================================
# Deployer wallet (testnet only - DO NOT use with real funds)
# ============================================================
# Option A: Generate your own wallet
#   python -c "from eth_account import Account; a=Account.create(); print(f'Address: {a.address}\nKey: {a.key.hex()}')"
#   Then fund via faucet: https://cloud.google.com/application/web3/faucet/ethereum/sepolia
# Option B: Use the key provided by your professor (testnet only, zero real value)
DEPLOYER_PRIVATE_KEY=0x<FILL_YOUR_TESTNET_PRIVATE_KEY>

# ============================================================
# LLM APIs (for SC-11 LLM-Assisted notebook)
# ============================================================

# Option 1: Local LLM (OpenAI-compatible endpoint)
LLM_API_URL=http://localhost:5002/v1
LLM_API_KEY=your_local_key
LLM_MODEL=default

# Option 2: OpenRouter (all frontier models)
# Get key at https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-v1-your_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OpenAI-compatible alias (used by SC-11)
OPENAI_API_KEY=${LLM_API_KEY}
OPENAI_BASE_URL=${LLM_API_URL}

# ============================================================
# Execution mode
# ============================================================
BATCH_MODE=false
