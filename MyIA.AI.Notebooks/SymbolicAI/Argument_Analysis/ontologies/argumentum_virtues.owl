    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#ferisonSyllogism</IRI>
    <Literal xml:lang="EN">Ferison syllogism</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#ferisonSyllogism</IRI>
    <Literal xml:lang="FR">Syllogisme où la majeure est universelle négative, la mineure particulière affirmative et la conclusion particulière négative.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#ferisonSyllogism</IRI>
    <Literal xml:lang="EN">A syllogism in which the major premise is universal negative, the minor premise particular affirmative, and the conclusion particular negative.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#ferisonSyllogism</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Syllogism#Types_of_syllogisms</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#ferisonSyllogism</IRI>
    <Literal xml:lang="FR">https://fr.wikipedia.org/wiki/Syllogisme#Types_de_syllogismes</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#thirdfigureSyllogism</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#ferisonSyllogism</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#ferisonSyllogism</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#thirdfigureSyllogism</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#ferisonSyllogism</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Rule</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#ferisonSyllogism</IRI>
    <Literal xml:lang="FR">L'universelle négative et la particulière affirmative justifient-elles seulement la conclusion particulière négative ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fourthfigureSyllogism</IRI>
    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#inScheme" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fourthfigureSyllogism</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fourthfigureSyllogism</IRI>
    <Literal xml:lang="FR">Syllogisme de quatrième figure</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fourthfigureSyllogism</IRI>
    <Literal xml:lang="EN">Fourth-figure syllogism</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fourthfigureSyllogism</IRI>
    <Literal xml:lang="FR">Syllogisme où le terme moyen est prédicat dans la majeure et sujet dans la mineure, ce qui exige une analyse attentive de la conclusion.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fourthfigureSyllogism</IRI>
    <Literal xml:lang="EN">A syllogism in which the middle term is the predicate in the major premise and the subject in the minor premise, requiring careful analysis to validate the conclusion.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fourthfigureSyllogism</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Syllogism#Fourth_figure_syllogism</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fourthfigureSyllogism</IRI>
    <Literal xml:lang="FR">https://fr.wikipedia.org/wiki/Syllogisme#Syllogisme_de_quatri%C3%A8me_figure</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validSyllogism</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fourthfigureSyllogism</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fourthfigureSyllogism</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validSyllogism</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fourthfigureSyllogism</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Rule</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fourthfigureSyllogism</IRI>
    <Literal xml:lang="FR">La position du terme moyen en quatrième figure permet-elle la conclusion avec la bonne quantité et la bonne qualité ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
