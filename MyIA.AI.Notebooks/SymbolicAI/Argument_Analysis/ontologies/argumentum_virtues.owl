    <IRI>https://www.argumentum.games/argumentum_virtues.owl#independenceOfPremisesFromTheConclusion</IRI>
    <Literal xml:lang="FR">Indépendance des prémisses</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#independenceOfPremisesFromTheConclusion</IRI>
    <Literal xml:lang="EN">Independence of premises from the conclusion</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#independenceOfPremisesFromTheConclusion</IRI>
    <Literal xml:lang="FR">Les prémisses doivent soutenir la conclusion sans la présupposer.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#independenceOfPremisesFromTheConclusion</IRI>
    <Literal xml:lang="EN">Premises must support the conclusion without presupposing it.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#independenceOfPremisesFromTheConclusion</IRI>
