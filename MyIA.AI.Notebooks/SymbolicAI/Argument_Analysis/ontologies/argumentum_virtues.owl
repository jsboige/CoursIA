    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectfulRefutationOfOpposingArguments</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectfulRefutationOfOpposingArguments</IRI>
    <Literal xml:lang="FR">Réfutation respectueuse</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectfulRefutationOfOpposingArguments</IRI>
    <Literal xml:lang="EN">Respectful refutation of opposing arguments</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectfulRefutationOfOpposingArguments</IRI>
    <Literal xml:lang="FR">Réfuter les arguments contraires avec précision, sans les altérer, les dénaturer ni les caricaturer.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectfulRefutationOfOpposingArguments</IRI>
    <Literal xml:lang="EN">Precise understanding of the opponent's arguments without altering, distorting, or caricaturing them.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectfulRefutationOfOpposingArguments</IRI>
    <Literal xml:lang="FR">https://www.developpez.net/forums/d1071995/general-developpement/philosophie-projet/argumentation/critique-adverse-ca-veritable-discussion-possible/</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#reasonableEvaluationOfTheOpposingPosition</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectfulRefutationOfOpposingArguments</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectfulRefutationOfOpposingArguments</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#reasonableEvaluationOfTheOpposingPosition</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectfulRefutationOfOpposingArguments</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Commitment</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectfulRefutationOfOpposingArguments</IRI>
    <Literal xml:lang="FR">La réfutation répond-elle précisément aux engagements réels de l'argument adverse ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForTheOriginOfIdeas</IRI>
    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#inScheme" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForTheOriginOfIdeas</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForTheOriginOfIdeas</IRI>
    <Literal xml:lang="FR">Respect de l’origine des idées</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForTheOriginOfIdeas</IRI>
    <Literal xml:lang="EN">Respect for the origin of ideas</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForTheOriginOfIdeas</IRI>
    <Literal xml:lang="FR">Respecter l’origine et l’authenticité des idées de chaque participant, tout en les jugeant pour ce qu’elles sont, indépendamment de leur auteur.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForTheOriginOfIdeas</IRI>
    <Literal xml:lang="EN">Respect for the origin of each participant’s ideas in a debate, their authenticity, and their contribution when it benefits understanding, while accepting that they be judged for what they are independently of those who put them forward.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForTheOriginOfIdeas</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Respect</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForTheOriginOfIdeas</IRI>
    <Literal xml:lang="FR">https://fr.wikipedia.org/wiki/Respect</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForThePerson</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForTheOriginOfIdeas</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForTheOriginOfIdeas</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForThePerson</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForTheOriginOfIdeas</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Commitment</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForTheOriginOfIdeas</IRI>
    <Literal xml:lang="FR">L'origine d'une idée est-elle reconnue sans remplacer l'évaluation de son contenu ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#principleOfNondisqualification</IRI>
    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#inScheme" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#principleOfNondisqualification</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#principleOfNondisqualification</IRI>
    <Literal xml:lang="FR">Principe de non-disqualification</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#principleOfNondisqualification</IRI>
    <Literal xml:lang="EN">Principle of non-disqualification</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#principleOfNondisqualification</IRI>
    <Literal xml:lang="FR">Éviter de disqualifier d’emblée un interlocuteur ou ses arguments en raison de son origine ou de ses affiliations.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#principleOfNondisqualification</IRI>
    <Literal xml:lang="EN">Avoiding a priori disqualification of one’s interlocutor or their arguments on the basis of origin or affiliations.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#principleOfNondisqualification</IRI>
    <Literal xml:lang="EN">https://www.gatesnotes.com/Development/Critical-thinking</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#principleOfNondisqualification</IRI>
    <Literal xml:lang="FR">https://www.gatesnotes.com/Development/Critical-thinking</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForTheOriginOfIdeas</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#principleOfNondisqualification</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#principleOfNondisqualification</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForTheOriginOfIdeas</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#principleOfNondisqualification</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Bias</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#principleOfNondisqualification</IRI>
    <Literal xml:lang="FR">L'origine ou l'affiliation invoquée suffit-elle réellement à invalider l'argument ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#valuingTheProvenanceOfIdeas</IRI>
    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#inScheme" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#valuingTheProvenanceOfIdeas</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#valuingTheProvenanceOfIdeas</IRI>
    <Literal xml:lang="FR">Valorisation de la provenance</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#valuingTheProvenanceOfIdeas</IRI>
    <Literal xml:lang="EN">Valuing the provenance of ideas</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#valuingTheProvenanceOfIdeas</IRI>
    <Literal xml:lang="FR">Reconnaître le rôle de chacun dans la genèse des idées afin de renforcer l’intégrité et la richesse du débat.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#valuingTheProvenanceOfIdeas</IRI>
    <Literal xml:lang="EN">Recognition of each person’s role in the genesis of ideas fosters the integrity and enrichment of debate.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#valuingTheProvenanceOfIdeas</IRI>
    <Literal xml:lang="EN">https://www.jc-counselling.com/single-post/2018/04/14/The-Importance-of-Recognizing-the-Value-of-Every-Contribution</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#valuingTheProvenanceOfIdeas</IRI>
    <Literal xml:lang="FR">https://www.jc-counselling.com/single-post/2018/04/14/The-Importance-of-Recognizing-the-Value-of-Every-Contribution</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForTheOriginOfIdeas</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#valuingTheProvenanceOfIdeas</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#valuingTheProvenanceOfIdeas</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForTheOriginOfIdeas</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#valuingTheProvenanceOfIdeas</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Witness Testimony</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#valuingTheProvenanceOfIdeas</IRI>
    <Literal xml:lang="FR">La provenance de l'idée est-elle attribuée fidèlement et utilisée de façon pertinente ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#argumentativeCollaboration</IRI>
    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#inScheme" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#argumentativeCollaboration</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#argumentativeCollaboration</IRI>
    <Literal xml:lang="FR">Collaboration argumentative</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#argumentativeCollaboration</IRI>
    <Literal xml:lang="EN">Argumentative collaboration</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#argumentativeCollaboration</IRI>
    <Literal xml:lang="FR">Créer un espace où les idées des participants sont combinées et respectées pour élaborer des solutions concertées.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#argumentativeCollaboration</IRI>
    <Literal xml:lang="EN">Creation of a space where the ideas of all participants are combined and respected, making it possible to develop coordinated solutions.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForTheOriginOfIdeas</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#argumentativeCollaboration</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#argumentativeCollaboration</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForTheOriginOfIdeas</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#argumentativeCollaboration</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Commitment</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#argumentativeCollaboration</IRI>
    <Literal xml:lang="FR">Les participants construisent-ils ensemble à partir de leurs engagements communs plutôt que de bloquer l'échange ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#courtesyInDisagreement</IRI>
    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#inScheme" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#courtesyInDisagreement</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#courtesyInDisagreement</IRI>
    <Literal xml:lang="FR">Courtoisie dans le désaccord</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#courtesyInDisagreement</IRI>
    <Literal xml:lang="EN">Courtesy in disagreement</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#courtesyInDisagreement</IRI>
    <Literal xml:lang="FR">Maintenir un dialogue constructif par une attitude respectueuse, malgré les divergences d'opinion.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#courtesyInDisagreement</IRI>
    <Literal xml:lang="EN">Maintaining constructive dialogue through a respectful attitude, despite differences of opinion.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#courtesyInDisagreement</IRI>
    <Literal xml:lang="FR">https://www.agoracademie.com/respect-mutuel-et-respect-de-l-autre-dans-l-echange-constructif/</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForThePerson</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#courtesyInDisagreement</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#courtesyInDisagreement</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForThePerson</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#courtesyInDisagreement</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Commitment</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#courtesyInDisagreement</IRI>
    <Literal xml:lang="FR">Le désaccord est-il exprimé de manière compatible avec la poursuite du dialogue ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#avoidingPersonalAttacks</IRI>
    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#inScheme" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#avoidingPersonalAttacks</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#avoidingPersonalAttacks</IRI>
    <Literal xml:lang="FR">Éviter les attaques personnelles</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#avoidingPersonalAttacks</IRI>
    <Literal xml:lang="EN">Avoiding personal attacks</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#avoidingPersonalAttacks</IRI>
    <Literal xml:lang="FR">Se concentrer sur l'argumentation concrète plutôt que critiquer, insulter ou ridiculiser son interlocuteur.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#avoidingPersonalAttacks</IRI>
    <Literal xml:lang="EN">Focusing on the actual argument rather than criticizing, insulting, or ridiculing one’s interlocutor preserves mutual respect.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#avoidingPersonalAttacks</IRI>
    <Literal xml:lang="FR">https://www.lesmotssontdescadeaux.com/2018/02/comment-critiquer-sans-agresser.html</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#courtesyInDisagreement</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#avoidingPersonalAttacks</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#avoidingPersonalAttacks</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#courtesyInDisagreement</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#avoidingPersonalAttacks</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Bias</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#avoidingPersonalAttacks</IRI>
    <Literal xml:lang="FR">Les traits personnels invoqués sont-ils pertinents pour évaluer l'argument présenté ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#nonviolentCommunication</IRI>
    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#inScheme" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#nonviolentCommunication</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#nonviolentCommunication</IRI>
    <Literal xml:lang="FR">Communication non violente</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#nonviolentCommunication</IRI>
    <Literal xml:lang="EN">Nonviolent communication</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#nonviolentCommunication</IRI>
    <Literal xml:lang="FR">Résoudre les conflits par la bienveillance, l'écoute active et l'empathie envers son interlocuteur.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#nonviolentCommunication</IRI>
    <Literal xml:lang="EN">A communication method encouraging conflict resolution through kindness and empathy toward one’s interlocutor.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#nonviolentCommunication</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Nonviolent_Communication</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
