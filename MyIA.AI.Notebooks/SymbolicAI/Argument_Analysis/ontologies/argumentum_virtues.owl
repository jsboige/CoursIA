    <Literal xml:lang="FR">Principe de charité</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#principleOfCharity</IRI>
    <Literal xml:lang="EN">Principle of charity</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#principleOfCharity</IRI>
    <Literal xml:lang="FR">Interpréter les arguments de votre interlocuteur dans leur version la plus forte et la plus cohérente.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#principleOfCharity</IRI>
    <Literal xml:lang="EN">An intellectually honest approach that adopts the strongest and most coherent interpretation of the interlocutor's arguments.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#principleOfCharity</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Principle_of_charity</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#principleOfCharity</IRI>
    <Literal xml:lang="FR">https://fr.wikipedia.org/wiki/Principe_de_charit%C3%A9</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#effectiveParticipation</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#principleOfCharity</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#principleOfCharity</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#effectiveParticipation</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#principleOfCharity</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Commitment</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#principleOfCharity</IRI>
    <Literal xml:lang="FR">L'argument adverse est-il interprété selon l'engagement le plus cohérent que son auteur peut raisonnablement soutenir ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
