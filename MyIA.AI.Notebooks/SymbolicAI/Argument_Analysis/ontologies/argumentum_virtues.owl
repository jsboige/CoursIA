    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#sufficientExplanations</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#refutablePremises</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#refutablePremises</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#sufficientExplanations</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#refutablePremises</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Commitment</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#refutablePremises</IRI>
    <Literal xml:lang="FR">Les prémisses peuvent-elles être contestées et soumises à l'examen critique commun ?</Literal>
  </AnnotationAssertion>
