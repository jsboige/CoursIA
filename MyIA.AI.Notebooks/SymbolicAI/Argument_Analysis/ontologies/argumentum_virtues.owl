    <Literal xml:lang="FR">https://fr.wikipedia.org/wiki/Objectivit%C3%A9_(philosophie)</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#intellectualHonesty</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#objectivityEffort</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#objectivityEffort</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#intellectualHonesty</IRI>
  </AnnotationAssertion>
