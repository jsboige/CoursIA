    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#refutablePremises</IRI>
    <Literal xml:lang="FR">Prémisses réfutables</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#refutablePremises</IRI>
    <Literal xml:lang="EN">Refutable premises</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#refutablePremises</IRI>
    <Literal xml:lang="FR">Les prémisses d’un argument doivent pouvoir être contestées, afin de permettre un débat constructif et d’éviter les affirmations irréfutables.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#refutablePremises</IRI>
    <Literal xml:lang="EN">The foundations of an argument must be open to challenge, allowing constructive debate and avoiding irrefutable claims.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#refutablePremises</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Falsifiability</Literal>
  </AnnotationAssertion>
