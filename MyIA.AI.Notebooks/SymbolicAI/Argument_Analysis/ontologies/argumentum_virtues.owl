    <IRI>https://www.argumentum.games/argumentum_virtues.owl#consistentDefinition</IRI>
    <Literal xml:lang="FR">La définition fixe-t-elle un sens non contradictoire et clairement applicable ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
