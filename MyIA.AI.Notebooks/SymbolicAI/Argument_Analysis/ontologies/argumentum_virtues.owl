    <IRI>https://www.argumentum.games/argumentum_virtues.owl#sufficientLevelOfProof</IRI>
    <Literal xml:lang="FR">Preuves suffisantes</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#sufficientLevelOfProof</IRI>
    <Literal xml:lang="EN">Sufficient level of proof</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#sufficientLevelOfProof</IRI>
    <Literal xml:lang="FR">Quiconque affirme une proposition doit pouvoir fournir des preuves suffisantes pour convaincre son interlocuteur.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#sufficientLevelOfProof</IRI>
    <Literal xml:lang="EN">The person asserting a proposition must be able to provide sufficient evidence to convince the recipient.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#sufficientLevelOfProof</IRI>
