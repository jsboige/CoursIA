    <IRI>https://www.argumentum.games/argumentum_virtues.owl#daraptiSyllogism</IRI>
    <Literal xml:lang="EN">Darapti syllogism</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#daraptiSyllogism</IRI>
    <Literal xml:lang="FR">Syllogisme où les deux prémisses sont des énoncés universels affirmatifs et la conclusion est un énoncé particulier affirmatif.</Literal>
  </AnnotationAssertion>
