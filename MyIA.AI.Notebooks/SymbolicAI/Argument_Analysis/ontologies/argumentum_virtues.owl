    <Literal xml:lang="FR">Raisonnement concluant</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#conclusiveReasoning</IRI>
    <Literal xml:lang="EN">Conclusive reasoning</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#conclusiveReasoning</IRI>
    <Literal xml:lang="FR">Application rigoureuse de la logique déductive pour parvenir à une conclusion nécessaire.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#conclusiveReasoning</IRI>
    <Literal xml:lang="EN">Rigorous application of the principles of deductive logic to reach an indisputable conclusion.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
