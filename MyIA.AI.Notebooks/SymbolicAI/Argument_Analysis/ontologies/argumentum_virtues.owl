    <IRI>https://www.argumentum.games/argumentum_virtues.owl#absenceOfInternalContradictions</IRI>
    <Literal xml:lang="FR">Cohérence interne</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#absenceOfInternalContradictions</IRI>
    <Literal xml:lang="EN">Absence of internal contradictions</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#absenceOfInternalContradictions</IRI>
    <Literal xml:lang="FR">Un raisonnement est valide si ses prémisses et sa conclusion ne se contredisent pas.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#absenceOfInternalContradictions</IRI>
    <Literal xml:lang="EN">A reasoning process is considered valid when its premises and conclusion are free from any logical contradiction.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#absenceOfInternalContradictions</IRI>
