    <Literal xml:lang="EN">Inference: Reductio ad absurdum</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#inference:ReductioAdAbsurdum</IRI>
    <Literal xml:lang="FR">Technique qui établit une proposition en montrant que son contraire mène à une contradiction.</Literal>
  </AnnotationAssertion>
