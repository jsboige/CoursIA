    <IRI>https://www.argumentum.games/argumentum_virtues.owl#enlightenedSelfdeprecation</IRI>
    <Literal xml:lang="FR">Autodérision éclairée</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#enlightenedSelfdeprecation</IRI>
    <Literal xml:lang="EN">Enlightened self-deprecation</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#enlightenedSelfdeprecation</IRI>
    <Literal xml:lang="FR">Art de l'autodérision, manifestant l'humilité et favorisant une dynamique constructive du débat.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#enlightenedSelfdeprecation</IRI>
    <Literal xml:lang="EN">The art of self-deprecation as a manifestation of humility that contributes to a constructive debate dynamic.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#enlightenedSelfdeprecation</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Self-deprecation</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#enlightenedSelfdeprecation</IRI>
    <Literal xml:lang="FR">https://fr.wikipedia.org/wiki/Autod%C3%A9rision</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectfulHumor</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#enlightenedSelfdeprecation</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#enlightenedSelfdeprecation</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectfulHumor</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#enlightenedSelfdeprecation</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Commitment</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#enlightenedSelfdeprecation</IRI>
    <Literal xml:lang="FR">L'autodérision favorise-t-elle une discussion ouverte plutôt qu'une stratégie de domination ou de connivence ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#inclusiveHumor</IRI>
    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#inScheme" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#inclusiveHumor</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#inclusiveHumor</IRI>
    <Literal xml:lang="FR">Humour inclusif</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#inclusiveHumor</IRI>
    <Literal xml:lang="EN">Inclusive humor</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#inclusiveHumor</IRI>
    <Literal xml:lang="FR">Humour qui respecte la diversité des individus, sans propos discriminatoires ni excluants.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#inclusiveHumor</IRI>
    <Literal xml:lang="EN">Use of humor that respects the diversity of individuals without making discriminatory or excluding remarks.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#tastefulHumour</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#inclusiveHumor</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#inclusiveHumor</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#tastefulHumour</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#inclusiveHumor</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Values</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#inclusiveHumor</IRI>
    <Literal xml:lang="FR">L'humour inclut-il l'auditoire sans exploiter de stéréotypes ni exclure des personnes ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateStyle</IRI>
    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#inScheme" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateStyle</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateStyle</IRI>
    <Literal xml:lang="FR">Style adapté</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateStyle</IRI>
    <Literal xml:lang="EN">Appropriate style</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateStyle</IRI>
    <Literal xml:lang="FR">Choisir des formules stylistiques et poétiques qui clarifient et enrichissent le message selon le sujet et l'audience.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateStyle</IRI>
    <Literal xml:lang="EN">Choosing stylistic and poetic forms that help clarify and enrich the message, depending on the subject and the audience.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateStyle</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Rhetoric</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateStyle</IRI>
    <Literal xml:lang="FR">https://fr.wikipedia.org/wiki/Rh%C3%A9torique</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#acceptableRhetoric</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateStyle</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateStyle</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#acceptableRhetoric</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateStyle</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Analogy</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateStyle</IRI>
    <Literal xml:lang="FR">Le style ou l'image employés éclairent-ils réellement le propos sans le rendre ambigu ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#eloquenceInTheServiceOfTruth</IRI>
    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#inScheme" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#eloquenceInTheServiceOfTruth</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#eloquenceInTheServiceOfTruth</IRI>
    <Literal xml:lang="FR">Éloquence véridique</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#eloquenceInTheServiceOfTruth</IRI>
    <Literal xml:lang="EN">Eloquence in the service of truth</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#eloquenceInTheServiceOfTruth</IRI>
    <Literal xml:lang="FR">Employer les ressources stylistiques pour exprimer l'argument avec clarté et précision, sans déformer le message initial.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#eloquenceInTheServiceOfTruth</IRI>
    <Literal xml:lang="EN">The use of stylistic elements should favor the clear and precise expression of the argument, without distorting the original message.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#eloquenceInTheServiceOfTruth</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Rhetoric</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#eloquenceInTheServiceOfTruth</IRI>
    <Literal xml:lang="FR">https://fr.wikipedia.org/wiki/Rh%C3%A9torique#Figure_de_style_et_proc%C3%A9d%C3%A9s_rh%C3%A9toriques_acceptables</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateStyle</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#eloquenceInTheServiceOfTruth</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#eloquenceInTheServiceOfTruth</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateStyle</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#eloquenceInTheServiceOfTruth</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Verbal Classification</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#eloquenceInTheServiceOfTruth</IRI>
    <Literal xml:lang="FR">L'expression éloquente demeure-t-elle fidèle au contenu initial de l'argument ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#figuresSupportingClarity</IRI>
    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#inScheme" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#figuresSupportingClarity</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#figuresSupportingClarity</IRI>
    <Literal xml:lang="FR">Figures soutenant la clarté</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#figuresSupportingClarity</IRI>
    <Literal xml:lang="EN">Figures supporting clarity</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#figuresSupportingClarity</IRI>
    <Literal xml:lang="FR">Utiliser des figures de style pour enrichir le discours et le rendre plus attrayant, sans nuire à la compréhension ni à la vérité des arguments.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#figuresSupportingClarity</IRI>
    <Literal xml:lang="EN">Using figures of speech to enrich the discourse and make it more appealing, without harming the understanding or truth of the arguments.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#figuresSupportingClarity</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Figure_of_speech</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#figuresSupportingClarity</IRI>
    <Literal xml:lang="FR">https://fr.wikipedia.org/wiki/Figure_de_style#R%C3%B4le_et_utilit%C3%A9</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#eloquenceInTheServiceOfTruth</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#figuresSupportingClarity</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#figuresSupportingClarity</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#eloquenceInTheServiceOfTruth</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#figuresSupportingClarity</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Analogy</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#figuresSupportingClarity</IRI>
    <Literal xml:lang="FR">La figure de style rend-elle l'argument plus intelligible sans créer d'ambiguïté ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#emotionalBalance</IRI>
    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#inScheme" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#emotionalBalance</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#emotionalBalance</IRI>
    <Literal xml:lang="FR">Équilibre émotionnel</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#emotionalBalance</IRI>
    <Literal xml:lang="EN">Emotional balance</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#emotionalBalance</IRI>
    <Literal xml:lang="FR">Maintenir une distance émotionnelle appropriée pour ne pas influencer indûment l'auditeur, tout en favorisant une réflexion rationnelle.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#emotionalBalance</IRI>
    <Literal xml:lang="EN">Maintaining an appropriate emotional distance so as not to unduly influence the listener with emotions, while allowing rational reflection.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#emotionalBalance</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Distancing</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#emotionalBalance</IRI>
    <Literal xml:lang="FR">https://fr.wikipedia.org/wiki/Distanciation_(psychologie)</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#honestPresentation</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#emotionalBalance</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#emotionalBalance</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#honestPresentation</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#emotionalBalance</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Values</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#emotionalBalance</IRI>
    <Literal xml:lang="FR">L’appel émotionnel reste-t-il proportionné et compatible avec une évaluation rationnelle de l’argument ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#emotionalNeutrality</IRI>
    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#inScheme" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#emotionalNeutrality</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#emotionalNeutrality</IRI>
    <Literal xml:lang="FR">Neutralité émotionnelle</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#emotionalNeutrality</IRI>
    <Literal xml:lang="EN">Emotional neutrality</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#emotionalNeutrality</IRI>
    <Literal xml:lang="FR">Éviter de rechercher l’adhésion par la complicité émotionnelle ; privilégier la transparence dans l’échange d’idées.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#emotionalNeutrality</IRI>
    <Literal xml:lang="EN">Avoiding seeking assent based on emotional rapport, favoring transparency in the exchange of ideas.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#emotionalNeutrality</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Collusion</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#emotionalNeutrality</IRI>
    <Literal xml:lang="FR">https://fr.wikipedia.org/wiki/Connivence_(psychologie)</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#emotionalBalance</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#emotionalNeutrality</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#emotionalNeutrality</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#emotionalBalance</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#emotionalNeutrality</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Bias</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#emotionalNeutrality</IRI>
    <Literal xml:lang="FR">L'adhésion recherchée repose-t-elle sur des raisons plutôt que sur une complicité émotionnelle biaisée ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#dramaticRestraint</IRI>
    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#inScheme" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#dramaticRestraint</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#dramaticRestraint</IRI>
    <Literal xml:lang="FR">Sobriété dramatique</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#dramaticRestraint</IRI>
    <Literal xml:lang="EN">Dramatic restraint</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#dramaticRestraint</IRI>
    <Literal xml:lang="FR">Éviter les effets de dramatisation excessifs qui faussent la perception de la situation présentée.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#dramaticRestraint</IRI>
    <Literal xml:lang="EN">The speaker avoids resorting to excessive dramatic effects that would risk distorting the audience's objective perception of the situation presented.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#dramaticRestraint</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Dramatization</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#dramaticRestraint</IRI>
    <Literal xml:lang="FR">https://fr.wikipedia.org/wiki/Dramatisation</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#emotionalBalance</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#dramaticRestraint</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#dramaticRestraint</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#emotionalBalance</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#dramaticRestraint</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Consequences</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#dramaticRestraint</IRI>
    <Literal xml:lang="FR">Les conséquences sont-elles présentées avec proportion, sans dramatisation qui fausse leur probabilité ou leur gravité ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#noBlackmailThroughConsequences</IRI>
    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#inScheme" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#noBlackmailThroughConsequences</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#noBlackmailThroughConsequences</IRI>
    <Literal xml:lang="FR">Sans chantage aux conséquences</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#noBlackmailThroughConsequences</IRI>
    <Literal xml:lang="EN">No blackmail through consequences</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#noBlackmailThroughConsequences</IRI>
    <Literal xml:lang="FR">Refuser de manipuler l’interlocuteur par des menaces ou des promesses liées aux conséquences.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#noBlackmailThroughConsequences</IRI>
    <Literal xml:lang="EN">Manipulating one's interlocutor by resorting to threats or promises constitutes an affront to honest and ethical exchange.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#noBlackmailThroughConsequences</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Emotional_blackmail</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#noBlackmailThroughConsequences</IRI>
    <Literal xml:lang="FR">https://www.psychologies.com/Therapies/Toutes-les-therapies/Therapies-breves/Articles-et-Dossiers/Le-chantage-affectif</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#emotionalBalance</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#noBlackmailThroughConsequences</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#noBlackmailThroughConsequences</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#emotionalBalance</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#noBlackmailThroughConsequences</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Consequences</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#noBlackmailThroughConsequences</IRI>
    <Literal xml:lang="FR">Les conséquences invoquées sont-elles pertinentes sans servir de menace ni de chantage ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#authenticCommunication</IRI>
    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#inScheme" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#authenticCommunication</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#authenticCommunication</IRI>
    <Literal xml:lang="FR">Communication authentique</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#authenticCommunication</IRI>
    <Literal xml:lang="EN">Authentic communication</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#authenticCommunication</IRI>
    <Literal xml:lang="FR">Favoriser un échange respectueux et constructif par l’écoute active, l’attention aux arguments de l’autre et la sincérité de ses propres positions.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#authenticCommunication</IRI>
    <Literal xml:lang="EN">Fostering respectful and constructive exchange by being attentive to the other person's arguments and showing active, caring listening.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#authenticCommunication</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Communication</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#authenticCommunication</IRI>
    <Literal xml:lang="FR">https://www.solen.ca/communication/conseils-et-astuces/7-attitudes-constructives-en-communication/</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#honestPresentation</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#authenticCommunication</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#authenticCommunication</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#honestPresentation</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#authenticCommunication</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Commitment</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#authenticCommunication</IRI>
    <Literal xml:lang="FR">Les positions exprimées sont-elles sincères et répondent-elles loyalement aux arguments de l’autre ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#transparency</IRI>
    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#inScheme" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#transparency</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#transparency</IRI>
    <Literal xml:lang="FR">Transparence</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#transparency</IRI>
    <Literal xml:lang="EN">Transparency</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#transparency</IRI>
    <Literal xml:lang="FR">Favoriser l’ouverture et la franchise dans les échanges, sans masquer vos intentions ni chercher à orienter le débat ou l’auditoire.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#transparency</IRI>
    <Literal xml:lang="EN">Encouragement of openness and frankness in exchanges without concealing intentions or seeking to influence the debate or the audience.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#transparency</IRI>
    <Literal xml:lang="FR">https://www.village-justice.com/articles/transparence-et-communication-dans-entreprise,35542.html</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#authenticCommunication</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#transparency</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#transparency</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#authenticCommunication</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#transparency</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Commitment</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#transparency</IRI>
    <Literal xml:lang="FR">Les intentions et informations pertinentes sont-elles déclarées franchement plutôt que dissimulées ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#benevolentNeutrality</IRI>
    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#inScheme" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#benevolentNeutrality</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#benevolentNeutrality</IRI>
    <Literal xml:lang="FR">Neutralité bienveillante</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#benevolentNeutrality</IRI>
    <Literal xml:lang="EN">Benevolent neutrality</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#benevolentNeutrality</IRI>
    <Literal xml:lang="FR">Adopter une position respectueuse des intérêts de l’autre, sans stratégie d’emprise ni ascendant psychologique.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#benevolentNeutrality</IRI>
    <Literal xml:lang="EN">Respectful position toward the interests of the other, non-strategic, and not seeking to exercise psychological leverage.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#benevolentNeutrality</IRI>
    <Literal xml:lang="FR">https://www.leadership-lavautoir.com/post/comment-adopter-une-position-neutre-en-tant-que-leader</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#authenticCommunication</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#benevolentNeutrality</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#benevolentNeutrality</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#authenticCommunication</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#benevolentNeutrality</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Bias</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#benevolentNeutrality</IRI>
    <Literal xml:lang="FR">La posture envers l'autre est-elle libre de stratégie d'emprise ou d'ascendant psychologique ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateStance</IRI>
    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#inScheme" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateStance</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateStance</IRI>
    <Literal xml:lang="FR">Posture appropriée</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateStance</IRI>
    <Literal xml:lang="EN">Appropriate stance</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateStance</IRI>
    <Literal xml:lang="FR">Adopter une attitude et des comportements adaptés à la situation de débat ou de discussion.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateStance</IRI>
    <Literal xml:lang="EN">Adoption of an attitude and behaviors appropriate and suited to the situation of debate or discussion.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateStance</IRI>
    <Literal xml:lang="FR">https://www.communication-sensible.com/post/5-techniques-de-communication-bienveillante-pour-mieux-dialoguer</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#authenticCommunication</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateStance</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateStance</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#authenticCommunication</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateStance</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Commitment</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateStance</IRI>
    <Literal xml:lang="FR">La posture et les comportements soutiennent-ils loyalement la discussion sans exercer d'influence indue ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#mathematicalAccuracy</IRI>
    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#inScheme" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#mathematicalAccuracy</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#mathematicalAccuracy</IRI>
    <Literal xml:lang="FR">Rigueur mathématique</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#mathematicalAccuracy</IRI>
    <Literal xml:lang="EN">Mathematical accuracy</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#mathematicalAccuracy</IRI>
    <Literal xml:lang="FR">Employer les mathématiques avec précision pour structurer et analyser des arguments ou des données.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#mathematicalAccuracy</IRI>
    <Literal xml:lang="EN">Careful and precise use of mathematics to structure and analyze arguments or data.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#mathematicalAccuracy</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Mathematical_method</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#mathematicalAccuracy</IRI>
    <Literal xml:lang="FR">https://fr.wikipedia.org/wiki/M%C3%A9thode_math%C3%A9matique</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgument</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#mathematicalAccuracy</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#mathematicalAccuracy</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgument</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#mathematicalAccuracy</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Sign</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#mathematicalAccuracy</IRI>
    <Literal xml:lang="FR">Le signe quantitatif invoqué est-il calculé correctement et constitue-t-il un indicateur fiable de la conclusion ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#justifiedGeneralizations</IRI>
    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
