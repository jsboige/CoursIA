    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fairInterpretation</IRI>
    <Literal xml:lang="EN">Fair interpretation</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fairInterpretation</IRI>
    <Literal xml:lang="FR">L'interprétation doit respecter les faits et tenir compte de tous les aspects pertinents, sans distorsion liée à des intérêts ou préjugés personnels.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fairInterpretation</IRI>
    <Literal xml:lang="EN">Interpretation conforming to the facts and taking into account all relevant aspects of the situation, without distortion by personal interests or prejudices.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fairInterpretation</IRI>
