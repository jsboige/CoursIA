    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#thirdfigureSyllogism</IRI>
    <Literal xml:lang="EN">Third-figure syllogism</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#thirdfigureSyllogism</IRI>
    <Literal xml:lang="FR">Raisonnement syllogistique où le terme moyen est sujet dans les deux prémisses, produisant généralement une conclusion particulière.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#thirdfigureSyllogism</IRI>
    <Literal xml:lang="EN">Syllogistic reasoning in which the middle term is the subject in both premises, generally producing a particular conclusion.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
