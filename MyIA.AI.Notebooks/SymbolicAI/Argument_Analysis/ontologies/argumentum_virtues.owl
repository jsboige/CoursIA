    <IRI>https://www.argumentum.games/argumentum_virtues.owl#understandingOthers’PersonalBiases</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#universality</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#understandingOthers’PersonalBiases</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Bias</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#understandingOthers’PersonalBiases</IRI>
    <Literal xml:lang="FR">Les biais possibles de l'interlocuteur sont-ils compris sans disqualifier abusivement sa position ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#interculturalAwareness</IRI>
    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#inScheme" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#interculturalAwareness</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#interculturalAwareness</IRI>
    <Literal xml:lang="FR">Conscience interculturelle</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#interculturalAwareness</IRI>
    <Literal xml:lang="EN">Intercultural awareness</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#interculturalAwareness</IRI>
    <Literal xml:lang="FR">Une pensée objective suppose de tenir compte des différences culturelles pour éviter l'ethnocentrisme.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#interculturalAwareness</IRI>
    <Literal xml:lang="EN">Objective thinking requires consideration of cultural differences in order to avoid ethnocentrism.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#interculturalAwareness</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Cultural_open-mindedness</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#interculturalAwareness</IRI>
    <Literal xml:lang="FR">https://fr.wikipedia.org/wiki/Ouverture_culturelle</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#objectivityEffort</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#interculturalAwareness</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#interculturalAwareness</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#objectivityEffort</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#interculturalAwareness</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Bias</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#interculturalAwareness</IRI>
    <Literal xml:lang="FR">Les différences culturelles pertinentes sont-elles prises en compte sans relativiser indûment la vérité ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#recognitionOfPersonalCulturalBiases</IRI>
    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#inScheme" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#recognitionOfPersonalCulturalBiases</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#recognitionOfPersonalCulturalBiases</IRI>
    <Literal xml:lang="FR">Reconnaître ses biais culturels</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#recognitionOfPersonalCulturalBiases</IRI>
    <Literal xml:lang="EN">Recognition of personal cultural biases</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#recognitionOfPersonalCulturalBiases</IRI>
    <Literal xml:lang="FR">Reconnaître l’influence de votre culture sur vos jugements et perceptions afin de mener une analyse plus équilibrée.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#recognitionOfPersonalCulturalBiases</IRI>
    <Literal xml:lang="EN">Recognition of the influence of one’s own culture on judgments and perceptions in order to achieve a more balanced analysis.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#recognitionOfPersonalCulturalBiases</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Cultural_bias</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#recognitionOfPersonalCulturalBiases</IRI>
    <Literal xml:lang="FR">https://www.scienceshumaines.com/les-biais-culturels-nouvelle-source-d-inegalites_fr_40797.html</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#interculturalAwareness</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#recognitionOfPersonalCulturalBiases</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#recognitionOfPersonalCulturalBiases</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#interculturalAwareness</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#recognitionOfPersonalCulturalBiases</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Bias</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#recognitionOfPersonalCulturalBiases</IRI>
    <Literal xml:lang="FR">L'influence de ma culture sur mon jugement a-t-elle été reconnue et corrigée ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#understandingOthersCulturalBiases</IRI>
    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
