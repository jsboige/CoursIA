    <IRI>https://www.argumentum.games/argumentum_virtues.owl#inference:UnitResolution</IRI>
    <Literal xml:lang="FR">Règle d’inférence qui simplifie une clause dès qu’un littéral unitaire en impose la valeur.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#inference:UnitResolution</IRI>
    <Literal xml:lang="EN">Reasoning method based on observing parts in order to reach an overall conclusion.</Literal>
  </AnnotationAssertion>
