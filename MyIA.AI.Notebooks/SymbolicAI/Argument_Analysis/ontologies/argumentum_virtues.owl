    <IRI>https://www.argumentum.games/argumentum_virtues.owl#tastefulHumour</IRI>
    <Literal xml:lang="FR">Humour de bon goût</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#tastefulHumour</IRI>
    <Literal xml:lang="EN">Tasteful humour</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#tastefulHumour</IRI>
    <Literal xml:lang="FR">Utiliser l’humour de manière appropriée, sans propos offensants ni déplacés.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#tastefulHumour</IRI>
    <Literal xml:lang="EN">Use of humour in an appropriate manner, without offensive remarks.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
