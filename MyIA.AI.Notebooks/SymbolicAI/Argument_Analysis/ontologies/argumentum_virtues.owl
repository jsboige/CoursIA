    <Literal xml:lang="FR">Termes techniques justifiés</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#justifiedTechnicalTerminology</IRI>
    <Literal xml:lang="EN">Justified technical terminology</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#justifiedTechnicalTerminology</IRI>
    <Literal xml:lang="FR">Expliquer clairement les termes techniques lorsqu’ils sont indispensables, afin de les rendre accessibles au public.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#justifiedTechnicalTerminology</IRI>
    <Literal xml:lang="EN">Clearly explaining technical terms when their use is unavoidable, in order to make them accessible to the public.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#justifiedTechnicalTerminology</IRI>
