    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#preciseIdentificationOfCausality</IRI>
    <Literal xml:lang="FR">Causalités bien identifiées</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#preciseIdentificationOfCausality</IRI>
    <Literal xml:lang="EN">Precise identification of causality</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#preciseIdentificationOfCausality</IRI>
    <Literal xml:lang="FR">Capacité à distinguer clairement les causes des effets dans un ensemble d'événements liés.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#preciseIdentificationOfCausality</IRI>
    <Literal xml:lang="EN">Ability to identify and clearly distinguish what is cause from what is effect within a set of interconnected events.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#preciseIdentificationOfCausality</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Causality</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
