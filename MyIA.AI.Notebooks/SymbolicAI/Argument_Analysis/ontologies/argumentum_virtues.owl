    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#occamsRazor</IRI>
    <Literal xml:lang="EN">Principle of simplicity recommending preferring the simplest explanations.</Literal>
