  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#discursiveAdaptation</IRI>
    <Literal xml:lang="FR">Adaptation discursive</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#discursiveAdaptation</IRI>
    <Literal xml:lang="EN">Discursive adaptation</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#discursiveAdaptation</IRI>
    <Literal xml:lang="FR">Ajustement du discours aux besoins et attentes de l’auditoire, sans perdre en intégrité.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#discursiveAdaptation</IRI>
    <Literal xml:lang="EN">Adjustment of rhetorical discourse so that it matches the audience’s needs and expectations while remaining grounded in integrity.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#discursiveAdaptation</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Rhetoric</Literal>
  </AnnotationAssertion>
