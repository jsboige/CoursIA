    <IRI>https://www.argumentum.games/argumentum_virtues.owl#resolutionPrinciple</IRI>
    <Literal xml:lang="EN">Resolution principle</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#resolutionPrinciple</IRI>
    <Literal xml:lang="FR">Approche constructive qui traite les désaccords par la discussion rationnelle et le consensus, en acceptant les conclusions issues d’un raisonnement concluant.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#resolutionPrinciple</IRI>
    <Literal xml:lang="EN">Constructive approach aimed at addressing disagreements through rational discussion and consensus, and at committing to accept the conclusions derived from conclusive reasoning.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#resolutionPrinciple</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Consensus_decision-making</Literal>
