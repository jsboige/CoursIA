    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#barbaraSyllogism</IRI>
    <Literal xml:lang="FR">Syllogisme Barbara</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#barbaraSyllogism</IRI>
    <Literal xml:lang="EN">Barbara syllogism</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#barbaraSyllogism</IRI>
    <Literal xml:lang="FR">Syllogisme parfait de forme A : deux propositions affirmatives universelles mènent à une conclusion affirmative universelle.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#barbaraSyllogism</IRI>
    <Literal xml:lang="EN">Perfect-mode syllogism of form A, in which two universal affirmative propositions lead to a universal affirmative conclusion.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#barbaraSyllogism</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Syllogism#Perfect_syllogisms</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#barbaraSyllogism</IRI>
    <Literal xml:lang="FR">https://fr.wikipedia.org/wiki/Syllogisme#Les_syllogismes_de_mode_parfait</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#perfectmodeSyllogism</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#barbaraSyllogism</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#barbaraSyllogism</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#perfectmodeSyllogism</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#barbaraSyllogism</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Rule</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#barbaraSyllogism</IRI>
    <Literal xml:lang="FR">Deux prémisses universelles affirmatives autorisent-elles bien la conclusion universelle affirmative ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
