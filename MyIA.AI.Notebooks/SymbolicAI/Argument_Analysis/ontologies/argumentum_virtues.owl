    <Literal xml:lang="FR">Positionnement clair</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#clearPositioning</IRI>
    <Literal xml:lang="EN">Clear positioning</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#clearPositioning</IRI>
    <Literal xml:lang="FR">Clarification de votre position dès le début du débat, afin d’éviter les malentendus et de rendre l’échange constructif.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#clearPositioning</IRI>
    <Literal xml:lang="EN">Clarification of one's position from the outset of the debate in order to avoid misunderstandings and make the debate constructive.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#clearPositioning</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Intellectual_honesty</Literal>
