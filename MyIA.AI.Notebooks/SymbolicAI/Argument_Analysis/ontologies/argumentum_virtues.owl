    <IRI>https://www.argumentum.games/argumentum_virtues.owl#clearPresentationOfData</IRI>
    <Literal xml:lang="FR">Données claires</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#clearPresentationOfData</IRI>
    <Literal xml:lang="EN">Clear presentation of data</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#clearPresentationOfData</IRI>
    <Literal xml:lang="FR">Les données sont présentées de façon claire, structurée et conforme aux protocoles de mesure, afin de permettre leur interprétation et leur vérification.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#clearPresentationOfData</IRI>
    <Literal xml:lang="EN">Data are presented in a clear, structured manner and in accordance with the measurement protocols used, in order to allow their interpretation and verification.</Literal>
  </AnnotationAssertion>
