    <IRI>https://www.argumentum.games/argumentum_virtues.owl#acceptableInformalLogic</IRI>
    <Literal xml:lang="FR">Raisonnement valable selon des critères non formels, comme la cohérence, la vraisemblance ou la force persuasive.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#acceptableInformalLogic</IRI>
    <Literal xml:lang="EN">Reasoning that is valid according to norms other than formal logic, such as coherence, plausibility, or persuasiveness.</Literal>
  </AnnotationAssertion>
