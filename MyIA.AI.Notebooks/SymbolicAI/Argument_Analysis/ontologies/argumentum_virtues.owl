  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#takingConflictsOfInterestIntoAccount</IRI>
    <Literal xml:lang="FR">Conflits d'intérêts</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#takingConflictsOfInterestIntoAccount</IRI>
    <Literal xml:lang="EN">Taking conflicts of interest into account</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#takingConflictsOfInterestIntoAccount</IRI>
    <Literal xml:lang="FR">Reconnaissez les conflits d'intérêts susceptibles d'influencer votre position afin de préserver votre indépendance et votre objectivité.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#takingConflictsOfInterestIntoAccount</IRI>
    <Literal xml:lang="EN">Recognizing conflicts of interest that could influence one’s position is essential to ensuring an independent and objective stance.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#takingConflictsOfInterestIntoAccount</IRI>
    <Literal xml:lang="EN">https://www.transparency.org/en/what-is-corruption/definitions</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#takingConflictsOfInterestIntoAccount</IRI>
    <Literal xml:lang="FR">https://www.transparency.org/fr/d%C3%A9finition-conflit-dint%C3%A9r%C3%AAt</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#identifyingWarningSigns</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#takingConflictsOfInterestIntoAccount</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#takingConflictsOfInterestIntoAccount</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#identifyingWarningSigns</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
