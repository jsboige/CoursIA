    <IRI>https://www.argumentum.games/argumentum_virtues.owl#scientificApproach</IRI>
    <Literal xml:lang="FR">Démarche scientifique</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#scientificApproach</IRI>
    <Literal xml:lang="EN">Scientific approach</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#scientificApproach</IRI>
    <Literal xml:lang="FR">Méthode objective, systématique et empirique visant à comprendre la réalité.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#scientificApproach</IRI>
    <Literal xml:lang="EN">Objective, systematic and empirical method of intellectual inquiry for understanding reality.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#scientificApproach</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Scientific_method</Literal>
  </AnnotationAssertion>
