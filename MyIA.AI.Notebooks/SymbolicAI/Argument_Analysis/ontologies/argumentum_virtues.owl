    <IRI>https://www.argumentum.games/argumentum_virtues.owl#balancedConsideration</IRI>
    <Literal xml:lang="EN">Maintaining neutrality in the presentation of facts by avoiding any bias.</Literal>
  </AnnotationAssertion>
