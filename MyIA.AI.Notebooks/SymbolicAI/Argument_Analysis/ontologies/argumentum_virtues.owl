    <IRI>https://www.argumentum.games/argumentum_virtues.owl#geometricAccuracy</IRI>
    <Literal xml:lang="FR">Les figures géométriques doivent être tracées avec précision, selon les règles de la géométrie classique, pour garantir la validité des résultats.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#geometricAccuracy</IRI>
    <Literal xml:lang="EN">Geometric figures must be drawn precisely, following the rules and principles of classical geometry, in order to ensure the validity of results in calculations involving space.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
