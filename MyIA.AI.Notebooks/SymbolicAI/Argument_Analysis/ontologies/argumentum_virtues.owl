    <IRI>https://www.argumentum.games/argumentum_virtues.owl#truthOfFacts</IRI>
    <Literal xml:lang="FR">Vérité des faits</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#truthOfFacts</IRI>
    <Literal xml:lang="EN">Truth of facts</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#truthOfFacts</IRI>
    <Literal xml:lang="FR">Présenter des faits précis, vérifiés et fidèles à la réalité, indépendamment des opinions ou des biais.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#truthOfFacts</IRI>
    <Literal xml:lang="EN">The facts presented must be precise, verified, and reflect reality independently of any opinion or bias.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#truthOfFacts</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Truth</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#truthOfFacts</IRI>
