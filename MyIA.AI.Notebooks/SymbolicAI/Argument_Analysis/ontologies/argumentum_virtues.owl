    <IRI>https://www.argumentum.games/argumentum_virtues.owl#positiveContribution</IRI>
    <Literal xml:lang="EN">Proactive and open approach, grounded in substantial arguments to feed a constructive dialogue.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
