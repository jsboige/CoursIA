    <IRI>https://www.argumentum.games/argumentum_virtues.owl#daraptiSyllogism</IRI>
    <Literal xml:lang="FR">Syllogisme Darapti</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
