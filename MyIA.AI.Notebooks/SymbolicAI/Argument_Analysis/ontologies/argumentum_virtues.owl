  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#perfectmodeSyllogism</IRI>
    <Literal xml:lang="FR">Syllogisme de mode parfait</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#perfectmodeSyllogism</IRI>
    <Literal xml:lang="EN">Perfect-mode syllogism</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#perfectmodeSyllogism</IRI>
    <Literal xml:lang="FR">Syllogisme qui respecte les règles des formes A, E, I ou O : chacun des trois termes apparaît deux fois, comme sujet ou comme prédicat.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#perfectmodeSyllogism</IRI>
    <Literal xml:lang="EN">Syllogism that follows the three rules of the A, E, I, or O form, in which each of the three terms is used twice, once as subject and once as predicate.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#perfectmodeSyllogism</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Syllogism#Perfect_syllogisms</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#perfectmodeSyllogism</IRI>
    <Literal xml:lang="FR">https://fr.wikipedia.org/wiki/Syllogisme#Les_syllogismes_de_mode_parfait</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validSyllogism</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#perfectmodeSyllogism</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#perfectmodeSyllogism</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validSyllogism</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#perfectmodeSyllogism</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Rule</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#perfectmodeSyllogism</IRI>
    <Literal xml:lang="FR">La règle syllogistique est-elle correctement appliquée aux trois termes et aux quantificateurs ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
