    <IRI>https://www.argumentum.games/argumentum_virtues.owl#correctOrientationOfCausality</IRI>
    <Literal xml:lang="FR">Causalité bien orientée</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#correctOrientationOfCausality</IRI>
    <Literal xml:lang="EN">Correct orientation of causality</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#correctOrientationOfCausality</IRI>
    <Literal xml:lang="FR">Capacité à reconnaître la direction correcte d'une relation causale entre deux ou plusieurs phénomènes.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#correctOrientationOfCausality</IRI>
    <Literal xml:lang="EN">Correct recognition of the direction of the causal relationship between two or more phenomena.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#correctOrientationOfCausality</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Causality</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
