  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#intellectualHonesty</IRI>
    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#inScheme" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#intellectualHonesty</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#intellectualHonesty</IRI>
    <Literal xml:lang="FR">Honnêteté intellectuelle</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#intellectualHonesty</IRI>
    <Literal xml:lang="EN">Intellectual honesty</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#intellectualHonesty</IRI>
    <Literal xml:lang="FR">Traiter honnêtement et avec neutralité vos sources, objectifs, positions et conclusions, afin de respecter les règles communes du débat ou de l’argumentation.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#intellectualHonesty</IRI>
    <Literal xml:lang="EN">Adopting an honest and neutral treatment of sources, objectives, positions and conclusions, in order to ensure the fair application of the shared rules of a debate or argumentation.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#intellectualHonesty</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Intellectual_honesty</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#intellectualHonesty</IRI>
    <Literal xml:lang="FR">https://fr.wikipedia.org/wiki/Honn%C3%AAtet%C3%A9_intellectuelle</Literal>
  </AnnotationAssertion>
