  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#objectivityEffort</IRI>
    <Literal xml:lang="FR">Effort d'objectivité</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#objectivityEffort</IRI>
    <Literal xml:lang="EN">Objectivity effort</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#objectivityEffort</IRI>
    <Literal xml:lang="FR">Cherchez à établir les faits avec impartialité, rigueur intellectuelle et attention aux biais.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#objectivityEffort</IRI>
    <Literal xml:lang="EN">An approach aimed at apprehending the truth of facts with impartiality and intellectual rigor.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#objectivityEffort</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Objectivity_(philosophy)</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
