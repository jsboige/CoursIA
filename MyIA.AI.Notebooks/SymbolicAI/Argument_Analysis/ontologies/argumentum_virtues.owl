    <Literal xml:lang="FR">Vocabulaire neutre</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#neutralVocabulary</IRI>
    <Literal xml:lang="EN">Neutral vocabulary</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#neutralVocabulary</IRI>
    <Literal xml:lang="FR">Adopter un vocabulaire objectif et impartial pour éviter les connotations biaisées et présenter les faits avec équilibre.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#neutralVocabulary</IRI>
    <Literal xml:lang="EN">Using objective, impartial vocabulary avoids confusion and biased connotations for a balanced and fair presentation.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#neutralVocabulary</IRI>
