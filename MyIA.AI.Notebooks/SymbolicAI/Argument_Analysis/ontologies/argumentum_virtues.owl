    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fidelityToFacts</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fidelityToFacts</IRI>
    <Literal xml:lang="FR">Fidélité aux faits</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fidelityToFacts</IRI>
    <Literal xml:lang="EN">Fidelity to facts</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fidelityToFacts</IRI>
    <Literal xml:lang="FR">Veiller à l’exactitude, à la pertinence et à la complétude des faits présentés pour préserver l’intégrité de l’argumentation.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fidelityToFacts</IRI>
    <Literal xml:lang="EN">Ensuring the accuracy, relevance and completeness of the facts presented in order to maintain the integrity of the argumentation.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fidelityToFacts</IRI>
