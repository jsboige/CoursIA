  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#noncomplacentObjective</IRI>
    <Literal xml:lang="FR">Fixez-vous le même niveau d'exigence qu'à votre adversaire, avec des critères clairs, mesurables et bien définis.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#noncomplacentObjective</IRI>
    <Literal xml:lang="EN">The objective set for oneself should meet the same level of rigor as that set for one’s opponent, with measurable, clear and well-defined criteria.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#noncomplacentObjective</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/SMART_criteria</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#noncomplacentObjective</IRI>
    <Literal xml:lang="FR">https://fr.wikipedia.org/wiki/Objectif_SMART</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#clarityOfIssues</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#noncomplacentObjective</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#noncomplacentObjective</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#clarityOfIssues</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#noncomplacentObjective</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Rule</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#noncomplacentObjective</IRI>
    <Literal xml:lang="FR">Les mêmes critères d'évaluation sont-ils appliqués à soi-même et à l'adversaire ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
