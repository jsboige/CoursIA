    <IRI>https://www.argumentum.games/argumentum_virtues.owl#understandingOthersCulturalBiases</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#understandingOthersCulturalBiases</IRI>
    <Literal xml:lang="FR">Comprendre les biais culturels d’autrui</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#understandingOthersCulturalBiases</IRI>
    <Literal xml:lang="EN">Understanding others' cultural biases</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#understandingOthersCulturalBiases</IRI>
    <Literal xml:lang="FR">Prendre en compte les biais culturels d’autrui pour mieux comprendre leurs perspectives et leurs discours.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#understandingOthersCulturalBiases</IRI>
    <Literal xml:lang="EN">Taking others' cultural biases into account for a better understanding of their perspectives and discourse.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#understandingOthersCulturalBiases</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Intercultural_communication</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#understandingOthersCulturalBiases</IRI>
    <Literal xml:lang="FR">https://www.communicaid.fr/communication-interculturelle/relation-professionnelle-interculturelle/</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#interculturalAwareness</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#understandingOthersCulturalBiases</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#understandingOthersCulturalBiases</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#interculturalAwareness</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#understandingOthersCulturalBiases</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Bias</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#understandingOthersCulturalBiases</IRI>
    <Literal xml:lang="FR">Les biais culturels d'autrui sont-ils pris en compte sans réduire son argument à son origine ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#distancingFromIdeologies</IRI>
    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#inScheme" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#distancingFromIdeologies</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#distancingFromIdeologies</IRI>
    <Literal xml:lang="FR">Mettre les idéologies à distance</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#distancingFromIdeologies</IRI>
    <Literal xml:lang="EN">Distancing from ideologies</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#distancingFromIdeologies</IRI>
    <Literal xml:lang="FR">Adopter une posture ouverte et neutre face aux idéologies afin d’évaluer les arguments avec impartialité.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#distancingFromIdeologies</IRI>
    <Literal xml:lang="EN">Adoption of a neutral and open approach toward various ideologies for an impartial assessment of arguments.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#distancingFromIdeologies</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Political_neutrality</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#distancingFromIdeologies</IRI>
    <Literal xml:lang="FR">https://www.franceculture.fr/societe/faut-il-etre-neutre-ou-partisan-sur-les-questions-de-societe</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#objectivityEffort</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#distancingFromIdeologies</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#distancingFromIdeologies</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#objectivityEffort</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#distancingFromIdeologies</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Bias</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#distancingFromIdeologies</IRI>
    <Literal xml:lang="FR">L'argument est-il évalué indépendamment de l'adhésion préalable à une idéologie ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#considerationOfOnesIdeologicalBiases</IRI>
    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#inScheme" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#considerationOfOnesIdeologicalBiases</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#considerationOfOnesIdeologicalBiases</IRI>
    <Literal xml:lang="FR">Reconnaître ses biais idéologiques</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#considerationOfOnesIdeologicalBiases</IRI>
    <Literal xml:lang="EN">Consideration of one's ideological biases</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#considerationOfOnesIdeologicalBiases</IRI>
    <Literal xml:lang="FR">Reconnaître vos biais idéologiques — convictions, croyances, préjugés ou stéréotypes — susceptibles d’influencer votre jugement.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#considerationOfOnesIdeologicalBiases</IRI>
    <Literal xml:lang="EN">Recognition of one’s own personal ideological biases linked to convictions, beliefs, prejudices and stereotypes, likely to influence judgment on a given issue.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#considerationOfOnesIdeologicalBiases</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Cognitive_bias</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#considerationOfOnesIdeologicalBiases</IRI>
    <Literal xml:lang="FR">https://fr.wikipedia.org/wiki/Biais_cognitif</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#distancingFromIdeologies</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#considerationOfOnesIdeologicalBiases</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#considerationOfOnesIdeologicalBiases</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#distancingFromIdeologies</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#considerationOfOnesIdeologicalBiases</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Bias</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#considerationOfOnesIdeologicalBiases</IRI>
    <Literal xml:lang="FR">Mes convictions idéologiques susceptibles d'influencer mon jugement ont-elles été reconnues ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
