  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#presumptionOfGoodFaith</IRI>
    <Literal xml:lang="FR">Présomption de bonne foi</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#presumptionOfGoodFaith</IRI>
    <Literal xml:lang="EN">Presumption of good faith</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#presumptionOfGoodFaith</IRI>
    <Literal xml:lang="FR">Supposer que vos interlocuteurs agissent honnêtement et de bonne foi, jusqu’à preuve du contraire.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#presumptionOfGoodFaith</IRI>
    <Literal xml:lang="EN">Adoption of the assumption that interlocutors act honestly and disinterestedly until proven otherwise.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#presumptionOfGoodFaith</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Principle_of_charity</Literal>
