    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fidelityToFacts</IRI>
    <Literal xml:lang="FR">Le témoignage ou l’énoncé factuel est-il exact, complet et corroboré par les faits disponibles ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
