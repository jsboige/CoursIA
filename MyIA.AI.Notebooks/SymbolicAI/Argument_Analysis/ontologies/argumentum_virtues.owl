    <IRI>https://www.argumentum.games/argumentum_virtues.owl#universality</IRI>
    <Literal xml:lang="FR">Les valeurs invoquées peuvent-elles être défendues au-delà d'un point de vue particulier ou partisan ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
