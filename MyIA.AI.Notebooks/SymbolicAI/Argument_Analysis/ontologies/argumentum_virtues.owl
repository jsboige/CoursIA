  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#presumptionOfGoodFaith</IRI>
    <Literal xml:lang="FR">Existe-t-il des raisons suffisantes de conclure que l'interlocuteur est de mauvaise foi ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForThePerson</IRI>
    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#inScheme" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForThePerson</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForThePerson</IRI>
    <Literal xml:lang="FR">Respect de la personne</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForThePerson</IRI>
    <Literal xml:lang="EN">Respect for the person</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForThePerson</IRI>
    <Literal xml:lang="FR">Traiter chaque participant avec égards, en reconnaissant sa dignité et la valeur de sa contribution.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForThePerson</IRI>
    <Literal xml:lang="EN">Fair and considerate treatment of each participant, valuing their contributions and ensuring individual dignity.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForThePerson</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Respect_for_personhood</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForThePerson</IRI>
    <Literal xml:lang="FR">https://fr.wikipedia.org/wiki/Valeurs_de_la_R%C3%A9publique_fran%C3%A7aise#Respect_de_la_personne_humaine</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fruitfulExchange</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForThePerson</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForThePerson</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fruitfulExchange</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForThePerson</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Bias</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForThePerson</IRI>
    <Literal xml:lang="FR">La critique porte-t-elle sur l’argument plutôt que sur la disqualification de la personne ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#reasonableEvaluationOfTheOpposingPosition</IRI>
    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#inScheme" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#reasonableEvaluationOfTheOpposingPosition</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#reasonableEvaluationOfTheOpposingPosition</IRI>
    <Literal xml:lang="FR">Évaluation loyale de la position adverse</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#reasonableEvaluationOfTheOpposingPosition</IRI>
    <Literal xml:lang="EN">Reasonable evaluation of the opposing position</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#reasonableEvaluationOfTheOpposingPosition</IRI>
    <Literal xml:lang="FR">Évaluer avec justesse les arguments adverses, sans déformer les propos, attaquer la personne ni lui prêter des raisonnements fallacieux.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#reasonableEvaluationOfTheOpposingPosition</IRI>
    <Literal xml:lang="EN">Fair and considered assessment of the opponent's arguments, without distorting their words, exploiting perceived contradictions in their person, or making them concede fallacious arguments.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#reasonableEvaluationOfTheOpposingPosition</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Constructive_criticism</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#reasonableEvaluationOfTheOpposingPosition</IRI>
    <Literal xml:lang="FR">https://fr.wikipedia.org/wiki/Critique#Critique_constructive</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForThePerson</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#reasonableEvaluationOfTheOpposingPosition</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#reasonableEvaluationOfTheOpposingPosition</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectForThePerson</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
