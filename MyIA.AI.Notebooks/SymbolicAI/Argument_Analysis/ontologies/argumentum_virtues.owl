    <Literal xml:lang="FR">https://www.cnvc.org/fr/</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#avoidingPersonalAttacks</IRI>
