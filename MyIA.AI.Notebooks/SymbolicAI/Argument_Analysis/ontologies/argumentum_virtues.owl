    <IRI>https://www.argumentum.games/argumentum_virtues.owl#acceptableInformalLogic</IRI>
    <Literal xml:lang="EN">Acceptable informal logic</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
