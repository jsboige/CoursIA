  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#stayingOnTopic</IRI>
    <Literal xml:lang="FR">Garder l'argumentation centrée sur le sujet afin de préserver la pertinence et l'efficacité de l'échange.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#stayingOnTopic</IRI>
    <Literal xml:lang="EN">Keeping the argumentation focused on the topic to preserve the relevance and productivity of discussions.</Literal>
  </AnnotationAssertion>
