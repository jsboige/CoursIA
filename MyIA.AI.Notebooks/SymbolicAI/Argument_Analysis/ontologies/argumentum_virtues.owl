  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#opennessToChange</IRI>
    <Literal xml:lang="EN">Openness to change</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#opennessToChange</IRI>
    <Literal xml:lang="FR">Disponibilité à revoir ses positions et à intégrer de nouvelles informations ou opinions justifiées.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#opennessToChange</IRI>
    <Literal xml:lang="EN">Willingness to reconsider one’s positions and integrate new information or justified opinions.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#opennessToChange</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Open-mindedness</Literal>
  </AnnotationAssertion>
