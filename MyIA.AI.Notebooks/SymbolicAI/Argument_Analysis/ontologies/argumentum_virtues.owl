    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#inScheme" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#acceptanceOfUncertainty</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#acceptanceOfUncertainty</IRI>
    <Literal xml:lang="FR">Acceptation de l'incertitude</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#acceptanceOfUncertainty</IRI>
    <Literal xml:lang="EN">Acceptance of uncertainty</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#acceptanceOfUncertainty</IRI>
    <Literal xml:lang="FR">Reconnaître que certaines questions restent incertaines et exigent parfois de décider selon les probabilités plutôt que sur des certitudes.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#acceptanceOfUncertainty</IRI>
    <Literal xml:lang="EN">Acceptance that certain questions remain without complete certainty, sometimes requiring decisions based on an assessment of probabilities rather than on established facts.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#acceptanceOfUncertainty</IRI>
