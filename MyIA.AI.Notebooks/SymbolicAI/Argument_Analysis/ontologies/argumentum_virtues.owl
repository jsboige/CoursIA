    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#premiseConsistency</IRI>
    <Literal xml:lang="EN">Ensures that the set of premises used in the reasoning is not only verifiable but also mutually consistent, without internal conflict.</Literal>
  </AnnotationAssertion>
