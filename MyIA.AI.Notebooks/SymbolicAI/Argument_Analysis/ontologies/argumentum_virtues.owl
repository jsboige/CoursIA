    <Literal xml:lang="FR">Exigence réaliste</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#realisticDemands</IRI>
    <Literal xml:lang="EN">Realistic demands</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
