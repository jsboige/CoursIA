    <IRI>https://www.argumentum.games/argumentum_virtues.owl#takingAllottedTimeIntoAccount</IRI>
    <Literal xml:lang="FR">Gérer le temps imparti</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#takingAllottedTimeIntoAccount</IRI>
    <Literal xml:lang="EN">Taking allotted time into account</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#takingAllottedTimeIntoAccount</IRI>
    <Literal xml:lang="FR">Prioriser les points essentiels du débat en fonction du temps disponible.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#takingAllottedTimeIntoAccount</IRI>
    <Literal xml:lang="EN">Prioritizing the crucial points of the debate while taking into account the time available for a productive meeting.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
