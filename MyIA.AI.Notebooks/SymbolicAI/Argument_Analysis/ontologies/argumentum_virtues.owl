    <IRI>https://www.argumentum.games/argumentum_virtues.owl#explicitJustifications</IRI>
    <Literal xml:lang="FR">Justifications explicites</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#explicitJustifications</IRI>
    <Literal xml:lang="EN">Explicit justifications</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
