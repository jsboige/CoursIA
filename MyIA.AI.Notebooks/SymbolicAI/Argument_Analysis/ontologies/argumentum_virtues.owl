  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#numericalAccuracy</IRI>
    <Literal xml:lang="FR">Les chiffres et nombres utilisés en mathématique sont choisis et traités avec rigueur afin d’assurer la fiabilité des résultats.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#numericalAccuracy</IRI>
    <Literal xml:lang="EN">Figures and numbers used in mathematics must be selected and handled rigorously in order to ensure the reliability of the results.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#numericalAccuracy</IRI>
