    <IRI>https://www.argumentum.games/argumentum_virtues.owl#searchForCompromise</IRI>
    <Literal xml:lang="EN">Search for compromise</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#searchForCompromise</IRI>
    <Literal xml:lang="FR">Stratégie de négociation où chaque partie fait des concessions pour parvenir à une solution satisfaisante.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#searchForCompromise</IRI>
    <Literal xml:lang="EN">Negotiation strategy in which each party accepts making concessions in order to reach a satisfactory solution.</Literal>
  </AnnotationAssertion>
