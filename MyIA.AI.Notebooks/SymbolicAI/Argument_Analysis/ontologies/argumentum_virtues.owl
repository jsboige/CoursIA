  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#principleOfClarity</IRI>
    <Literal xml:lang="EN">Principle of clarity</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#principleOfClarity</IRI>
    <Literal xml:lang="FR">Formuler une argumentation claire et précise pour faciliter la compréhension et maintenir l'échange sur le sujet principal.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#principleOfClarity</IRI>
    <Literal xml:lang="EN">Clear and precise argumentation facilitates understanding and helps keep the exchange on the main topic.</Literal>
  </AnnotationAssertion>
