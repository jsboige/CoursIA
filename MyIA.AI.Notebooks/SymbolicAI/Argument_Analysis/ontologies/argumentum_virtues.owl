    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fesapoSyllogism</IRI>
    <Literal xml:lang="FR">Deux prémisses universelles de Fesapo justifient-elles correctement une conclusion particulière négative ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fresisonSyllogism</IRI>
    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
