    <Literal xml:lang="FR">Définition cohérente</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#consistentDefinition</IRI>
    <Literal xml:lang="EN">Consistent definition</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#consistentDefinition</IRI>
    <Literal xml:lang="FR">Définition claire et non contradictoire qui fixe sans ambiguïté le sens d’un terme ou d’une expression.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#consistentDefinition</IRI>
    <Literal xml:lang="EN">A clear and non-contradictory definition that unambiguously fixes the meaning of a term or expression.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#consistentDefinition</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Definition</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
