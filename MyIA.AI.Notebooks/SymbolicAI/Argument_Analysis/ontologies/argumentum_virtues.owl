    <Literal xml:lang="FR">Vocabulaire approprié</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateVocabulary</IRI>
    <Literal xml:lang="EN">Appropriate vocabulary</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
