    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fairAttribution</IRI>
    <Literal xml:lang="EN">Fair attribution</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fairAttribution</IRI>
    <Literal xml:lang="FR">Attribuer fidèlement les sources et les citations afin de préserver l’intégrité intellectuelle et le respect des auteurs.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fairAttribution</IRI>
    <Literal xml:lang="EN">Faithful attribution of sources and quotations in order to maintain intellectual integrity and respect for authors.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fairAttribution</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Plagiarism</Literal>
