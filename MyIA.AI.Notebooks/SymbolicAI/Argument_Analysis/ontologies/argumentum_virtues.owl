    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateTechnicalTerminology</IRI>
    <Literal xml:lang="FR">Terminologie technique</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateTechnicalTerminology</IRI>
    <Literal xml:lang="EN">Appropriate technical terminology</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateTechnicalTerminology</IRI>
    <Literal xml:lang="FR">Emploi correct des termes propres à un domaine pour communiquer avec précision et sans ambiguïté.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateTechnicalTerminology</IRI>
    <Literal xml:lang="EN">Correct use of terminology specific to a field of study for unambiguous and professionally acceptable communication.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateTechnicalTerminology</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Technical_terminology</Literal>
  </AnnotationAssertion>
