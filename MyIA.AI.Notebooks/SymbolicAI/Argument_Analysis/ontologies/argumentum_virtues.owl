    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#justifiedGeneralizations</IRI>
    <Literal xml:lang="FR">Généralisations justifiées</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#justifiedGeneralizations</IRI>
    <Literal xml:lang="EN">Justified generalizations</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#justifiedGeneralizations</IRI>
    <Literal xml:lang="FR">Chaque généralisation doit reposer sur un échantillonnage robuste et une analyse objective des données.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#justifiedGeneralizations</IRI>
    <Literal xml:lang="EN">Each generalization rests on robust sampling and objective data analysis.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#justifiedGeneralizations</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Generalization</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
