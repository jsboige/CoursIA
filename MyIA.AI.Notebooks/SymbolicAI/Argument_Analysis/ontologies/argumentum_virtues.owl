    <Literal xml:lang="FR">https://fr.wikipedia.org/wiki/Pens%C3%A9e_critique</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#acceptableInformalLogic</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#correctCriticalReasoning</IRI>
