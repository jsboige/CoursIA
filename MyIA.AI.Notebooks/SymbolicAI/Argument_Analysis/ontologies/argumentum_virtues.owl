  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#acceptanceOfUncertainty</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#distancingFromIdeologies</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#acceptanceOfUncertainty</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Sign</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#acceptanceOfUncertainty</IRI>
    <Literal xml:lang="FR">Le degré d'incertitude est-il reconnu et traité par des probabilités fiables plutôt que par une certitude feinte ?</Literal>
