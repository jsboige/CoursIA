    <IRI>https://www.argumentum.games/argumentum_virtues.owl#recognitionOfPersonalBiases</IRI>
    <Literal xml:lang="FR">Reconnaître ses biais</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#recognitionOfPersonalBiases</IRI>
    <Literal xml:lang="EN">Recognition of personal biases</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#recognitionOfPersonalBiases</IRI>
    <Literal xml:lang="FR">Prendre conscience de vos propres biais cognitifs vous aide à développer une pensée plus objective.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#recognitionOfPersonalBiases</IRI>
    <Literal xml:lang="EN">Awareness of one’s own cognitive biases makes it possible to develop more objective thinking.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#recognitionOfPersonalBiases</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Cognitive_bias</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#recognitionOfPersonalBiases</IRI>
    <Literal xml:lang="FR">https://fr.wikipedia.org/wiki/Biais_cognitif</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#universality</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#recognitionOfPersonalBiases</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#recognitionOfPersonalBiases</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#universality</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#recognitionOfPersonalBiases</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Bias</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#recognitionOfPersonalBiases</IRI>
    <Literal xml:lang="FR">Mes propres biais susceptibles d'affecter le jugement ont-ils été identifiés ?</Literal>
  </AnnotationAssertion>
