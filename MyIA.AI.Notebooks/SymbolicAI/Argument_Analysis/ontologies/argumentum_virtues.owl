    <Literal xml:lang="FR">Raisonnement analytique solide</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#correctAnalyticalReasoning</IRI>
    <Literal xml:lang="EN">Correct analytical reasoning</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#correctAnalyticalReasoning</IRI>
    <Literal xml:lang="FR">Raisonnement qui décompose un ensemble complexe en éléments simples pour mieux le comprendre et l’évaluer.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#correctAnalyticalReasoning</IRI>
    <Literal xml:lang="EN">A thought process that breaks down a complex whole into simpler elements for deeper understanding and critical judgment.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#correctAnalyticalReasoning</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Analytical_reasoning</Literal>
