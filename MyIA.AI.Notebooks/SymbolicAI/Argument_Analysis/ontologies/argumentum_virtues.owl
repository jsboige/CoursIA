    <IRI>https://www.argumentum.games/argumentum_virtues.owl#identifyingWarningSigns</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#noncomplacentObjective</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#identifyingWarningSigns</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Danger</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#identifyingWarningSigns</IRI>
    <Literal xml:lang="FR">Les risques invoqués sont-ils réels, pertinents et accompagnés de mesures proportionnées ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
