    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Commitment</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#reasonableEvaluationOfTheOpposingPosition</IRI>
    <Literal xml:lang="FR">La critique vise-t-elle la position réellement défendue par l'interlocuteur ?</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#type" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#argumentfocusedCriticism</IRI>
    <IRI>http://www.w3.org/2004/02/skos/core#Concept</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#inScheme" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#argumentfocusedCriticism</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#argumentfocusedCriticism</IRI>
    <Literal xml:lang="FR">Critique axée sur les arguments</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#argumentfocusedCriticism</IRI>
    <Literal xml:lang="EN">Argument-focused criticism</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#argumentfocusedCriticism</IRI>
    <Literal xml:lang="FR">Formuler des critiques respectueuses qui portent sur le fond des arguments plutôt que sur les personnes.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#argumentfocusedCriticism</IRI>
    <Literal xml:lang="EN">Formulating respectful criticism that addresses arguments on their merits rather than targeting people.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#argumentfocusedCriticism</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Constructive_criticism</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#argumentfocusedCriticism</IRI>
    <Literal xml:lang="FR">https://fr.wikipedia.org/wiki/Critique#Critique_constructive</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#reasonableEvaluationOfTheOpposingPosition</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#argumentfocusedCriticism</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#argumentfocusedCriticism</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#reasonableEvaluationOfTheOpposingPosition</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#argumentfocusedCriticism</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Commitment</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
