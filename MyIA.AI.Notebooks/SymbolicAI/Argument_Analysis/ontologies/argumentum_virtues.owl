    <IRI>https://www.argumentum.games/argumentum_virtues.owl#exactCalculations</IRI>
    <Literal xml:lang="FR">Les chiffres, mesures et figures géométriques sont corrects, pertinents, significatifs et bien arrondis, afin d’assurer la validité des résultats.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#exactCalculations</IRI>
    <Literal xml:lang="EN">Figures, numbers, measurements and geometric shapes must be correct, relevant, meaningful and properly rounded in order to ensure the validity of the results.</Literal>
