    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validReasoning</IRI>
    <Literal xml:lang="EN">Valid reasoning</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validReasoning</IRI>
    <Literal xml:lang="FR">Méthode rigoureuse qui articule des prémisses acceptables et des règles d'inférence valides pour aboutir à une conclusion cohérente et justifiée.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validReasoning</IRI>
    <Literal xml:lang="EN">A rigorous method of reasoning based on the articulation of acceptable premises and acceptable rules of inference in order to reach a coherent and justified conclusion.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validReasoning</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Valid_reasoning</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validReasoning</IRI>
    <Literal xml:lang="FR">https://fr.wikipedia.org/wiki/Raisonnement_valide</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgument</IRI>
