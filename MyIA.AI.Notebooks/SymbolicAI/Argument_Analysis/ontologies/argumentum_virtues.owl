  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#balancedConsideration</IRI>
    <Literal xml:lang="FR">Présentation neutre des faits, sans parti pris.</Literal>
  </AnnotationAssertion>
