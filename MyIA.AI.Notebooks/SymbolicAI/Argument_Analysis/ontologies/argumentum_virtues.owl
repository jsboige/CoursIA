  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fruitfulExchange</IRI>
    <Literal xml:lang="FR">Dialogue structuré où l’écoute active et la considération mutuelle font progresser vers une entente ou une compréhension plus fine.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fruitfulExchange</IRI>
    <Literal xml:lang="EN">Structured dialogue in which active listening and mutual consideration guide progress toward agreement or deeper understanding.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#fruitfulExchange</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Constructive_dialogue</Literal>
  </AnnotationAssertion>
