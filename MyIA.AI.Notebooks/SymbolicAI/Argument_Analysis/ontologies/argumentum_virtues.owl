    <IRI>https://www.argumentum.games/argumentum_virtues.owl#understandingOthers’PersonalBiases</IRI>
    <Literal xml:lang="FR">Comprendre les biais d'autrui</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#understandingOthers’PersonalBiases</IRI>
    <Literal xml:lang="EN">Understanding others’ personal biases</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
