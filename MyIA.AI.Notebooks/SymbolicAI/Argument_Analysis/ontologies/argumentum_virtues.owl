    <Literal xml:lang="FR">Concentration sur l'essentiel</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#focusingOnTheEssentials</IRI>
    <Literal xml:lang="EN">Focusing on the essentials</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#focusingOnTheEssentials</IRI>
    <Literal xml:lang="FR">Aider les participants à cerner et discuter les éléments essentiels pour rendre l'échange plus efficace.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#focusingOnTheEssentials</IRI>
    <Literal xml:lang="EN">Ensuring that all participants identify, understand and discuss the most important elements to maximize the effectiveness of the discussion.</Literal>
  </AnnotationAssertion>
