    <Literal xml:lang="FR">Rhétorique éloquente</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#eloquentRhetoric</IRI>
    <Literal xml:lang="EN">Eloquent rhetoric</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#eloquentRhetoric</IRI>
    <Literal xml:lang="FR">Usage de techniques rhétoriques pour présenter un argument avec clarté, élégance et force, sans manipulation.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#eloquentRhetoric</IRI>
    <Literal xml:lang="EN">Use of rhetorical techniques to articulate an argument in a clear, aesthetic and convincing manner, without slipping into manipulation.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#eloquentRhetoric</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Rhetoric</Literal>
  </AnnotationAssertion>
