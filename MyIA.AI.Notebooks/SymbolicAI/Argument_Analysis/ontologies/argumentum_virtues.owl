    <IRI>https://www.argumentum.games/argumentum_virtues.owl#exclusionOfAlternativeCauses</IRI>
    <Literal xml:lang="FR">Exclusion des causes alternatives</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#exclusionOfAlternativeCauses</IRI>
    <Literal xml:lang="EN">Exclusion of alternative causes</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#exclusionOfAlternativeCauses</IRI>
    <Literal xml:lang="FR">Analyse méthodique visant à écarter les explications causales concurrentes pour retenir la plus plausible.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#exclusionOfAlternativeCauses</IRI>
    <Literal xml:lang="EN">Methodical analysis of a phenomenon to rule out any incorrect causal attribution by retaining only the most plausible cause.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#exclusionOfAlternativeCauses</IRI>
    <Literal xml:lang="EN">https://sophismes.net/raisonnement-valide/exclusion-des-causes-alternatives</Literal>
