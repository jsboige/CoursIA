    <IRI>https://www.argumentum.games/argumentum_virtues.owl#positiveContribution</IRI>
    <Literal xml:lang="FR">Approche proactive et ouverte, fondée sur des arguments substantiels pour nourrir un dialogue constructif.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
