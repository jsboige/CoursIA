    <Literal xml:lang="FR">Humour respectueux</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectfulHumor</IRI>
    <Literal xml:lang="EN">Respectful humor</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectfulHumor</IRI>
    <Literal xml:lang="FR">Recours à l'humour de manière respectueuse et appropriée, sans dénigrer ni blesser autrui.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectfulHumor</IRI>
    <Literal xml:lang="EN">Use of humor in a respectful and appropriate way without belittling or hurting others.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectfulHumor</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Rhetoric</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
