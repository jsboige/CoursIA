    <IRI>https://www.argumentum.games/argumentum_virtues.owl#contextappropriateHumor</IRI>
    <Literal xml:lang="FR">Humour adapté au contexte</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#contextappropriateHumor</IRI>
    <Literal xml:lang="EN">Context-appropriate humor</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#contextappropriateHumor</IRI>
    <Literal xml:lang="FR">Humour adapté à la maturité, aux connaissances et aux sensibilités culturelles de l'auditoire.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#contextappropriateHumor</IRI>
    <Literal xml:lang="EN">Use of humor adapted to the audience’s maturity, knowledge, and cultural sensitivities.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#contextappropriateHumor</IRI>
