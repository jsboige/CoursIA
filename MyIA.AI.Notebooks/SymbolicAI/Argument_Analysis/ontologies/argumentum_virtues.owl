  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#effectiveParticipation</IRI>
    <Literal xml:lang="FR">Participation active et respectueuse, visant à faire avancer le débat par des échanges productifs.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#effectiveParticipation</IRI>
    <Literal xml:lang="EN">Active, respectful participation aimed at moving the debate forward with productive exchanges.</Literal>
  </AnnotationAssertion>
