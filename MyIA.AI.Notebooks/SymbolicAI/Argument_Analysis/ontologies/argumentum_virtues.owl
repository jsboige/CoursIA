    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#takingTheOpponent’sIdeologicalBiasesIntoAccount</IRI>
    <Literal xml:lang="FR">Tenir compte des biais idéologiques</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#takingTheOpponent’sIdeologicalBiasesIntoAccount</IRI>
    <Literal xml:lang="EN">Taking the opponent’s ideological biases into account</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#takingTheOpponent’sIdeologicalBiasesIntoAccount</IRI>
    <Literal xml:lang="FR">Identifier les biais idéologiques des parties prenantes afin de contextualiser leurs arguments et de mieux formuler les vôtres.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#takingTheOpponent’sIdeologicalBiasesIntoAccount</IRI>
    <Literal xml:lang="EN">Identification and consideration of the ideological biases inherent in the parties to an exchange, making it possible to contextualize their arguments and perspectives as well as to facilitate the communication of one’s own.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#takingTheOpponent’sIdeologicalBiasesIntoAccount</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Cognitive_bias</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#takingTheOpponent’sIdeologicalBiasesIntoAccount</IRI>
    <Literal xml:lang="FR">https://www.edutechwiki.unige.ch/fr/Biais_cognitifs#Biais_d'attribution</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#distancingFromIdeologies</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#takingTheOpponent’sIdeologicalBiasesIntoAccount</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#takingTheOpponent’sIdeologicalBiasesIntoAccount</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#distancingFromIdeologies</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#takingTheOpponent’sIdeologicalBiasesIntoAccount</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Bias</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#takingTheOpponent’sIdeologicalBiasesIntoAccount</IRI>
    <Literal xml:lang="FR">Les biais idéologiques des parties sont-ils contextualisés sans servir à les discréditer d'avance ?</Literal>
