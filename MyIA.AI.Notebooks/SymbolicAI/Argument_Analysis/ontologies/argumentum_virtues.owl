    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateVocabulary</IRI>
    <Literal xml:lang="FR">Choix précis des termes pour renforcer la clarté et l’exactitude de l’argument.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateVocabulary</IRI>
    <Literal xml:lang="EN">Careful selection of specific terms to reinforce the clarity and accuracy of the argument presented.</Literal>
  </AnnotationAssertion>
