    <Literal xml:lang="FR">https://fr.wikipedia.org/wiki/Causalit%C3%A9</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#preciseIdentificationOfCausality</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#correctOrientationOfCausality</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#broader" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#correctOrientationOfCausality</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#preciseIdentificationOfCausality</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
