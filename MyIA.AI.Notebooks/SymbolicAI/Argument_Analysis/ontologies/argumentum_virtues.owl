    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validSyllogism</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validFormalLogic</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.arg.dundee.ac.uk/aif#goodTenorOf" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validSyllogism</IRI>
    <IRI>http://www.arg.dundee.ac.uk/aif#Argument from Rule</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
