  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#correctCriticalReasoning</IRI>
    <Literal xml:lang="FR">Évaluation rigoureuse des arguments visant à repérer les biais, les sophismes et les erreurs de raisonnement.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#correctCriticalReasoning</IRI>
    <Literal xml:lang="EN">A process of rigorous and methodical evaluation of arguments, aimed at avoiding biases and errors in reasoning.</Literal>
  </AnnotationAssertion>
