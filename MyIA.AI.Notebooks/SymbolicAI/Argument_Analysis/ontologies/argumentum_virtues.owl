    <Literal xml:lang="FR">Charge de la preuve</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#burdenOfProof</IRI>
    <Literal xml:lang="EN">Burden of proof</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#burdenOfProof</IRI>
    <Literal xml:lang="FR">Principe selon lequel celui qui avance une affirmation doit en démontrer la véracité, plutôt que d’exiger qu’on la réfute.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#burdenOfProof</IRI>
    <Literal xml:lang="EN">Principle according to which the person making an assertion has the duty to demonstrate its truth rather than to demand its refutation.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#burdenOfProof</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Burden_of_proof_(philosophy)</Literal>
  </AnnotationAssertion>
