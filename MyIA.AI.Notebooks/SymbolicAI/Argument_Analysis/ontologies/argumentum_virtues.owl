    <IRI>https://www.argumentum.games/argumentum_virtues.owl#justifiedComparisons</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#justifiedComparisons</IRI>
    <Literal xml:lang="FR">Comparaisons justifiées</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#justifiedComparisons</IRI>
    <Literal xml:lang="EN">Justified comparisons</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#justifiedComparisons</IRI>
    <Literal xml:lang="FR">Usage de comparaisons pertinentes et valides pour clarifier ou renforcer une argumentation.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#justifiedComparisons</IRI>
    <Literal xml:lang="EN">Use of comparisons to clarify and strengthen an argument, while ensuring their relevance and validity in the given context.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#justifiedComparisons</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Analogy</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#justifiedComparisons</IRI>
    <Literal xml:lang="FR">https://philosophie.cegeptr.qc.ca/wp-content/uploads/sites/2/2019/01/FICHE-6-Lanalyse-des-analogies.pdf</Literal>
  </AnnotationAssertion>
