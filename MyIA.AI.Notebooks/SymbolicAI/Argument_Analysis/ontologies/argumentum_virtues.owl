    <IRI>https://www.argumentum.games/argumentum_virtues.owl#understandingOthers’PersonalBiases</IRI>
    <Literal xml:lang="FR">Reconnaître les biais cognitifs de vos interlocuteurs aide à mieux comprendre leurs perspectives.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#understandingOthers’PersonalBiases</IRI>
    <Literal xml:lang="EN">Recognition of and attention to cognitive biases in interlocutors contribute to a better understanding of their perspectives.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#understandingOthers’PersonalBiases</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Cognitive_bias</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#understandingOthers’PersonalBiases</IRI>
    <Literal xml:lang="FR">https://fr.wikipedia.org/wiki/Biais_cognitif</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#universality</IRI>
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#understandingOthers’PersonalBiases</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
