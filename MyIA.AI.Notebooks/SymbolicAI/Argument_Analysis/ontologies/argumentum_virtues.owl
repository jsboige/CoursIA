    <Literal xml:lang="FR">https://fr.wikipedia.org/wiki/Honn%C3%AAtet%C3%A9_intellectuelle</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#narrower" />
