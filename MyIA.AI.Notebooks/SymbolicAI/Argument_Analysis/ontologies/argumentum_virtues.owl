    <Literal xml:lang="FR">Éviter les digressions</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#avoidingDigressions</IRI>
    <Literal xml:lang="EN">Avoiding digressions</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#avoidingDigressions</IRI>
    <Literal xml:lang="FR">Rester rigoureusement concentré sur le sujet principal pour préserver un échange constructif et pertinent.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#avoidingDigressions</IRI>
    <Literal xml:lang="EN">Rigorous concentration on the main topic for a constructive and relevant exchange.</Literal>
  </AnnotationAssertion>
