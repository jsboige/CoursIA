    <IRI>https://www.argumentum.games/argumentum_virtues.owl#nuancedConsiderations</IRI>
    <Literal xml:lang="EN">Impartial and comprehensive assessment and presentation of facts, taking different points of view into account.</Literal>
  </AnnotationAssertion>
