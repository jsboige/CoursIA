    <IRI>https://www.argumentum.games/argumentum_virtues.owl#universality</IRI>
    <Literal xml:lang="FR">Universalisme</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#universality</IRI>
    <Literal xml:lang="EN">Universality</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#universality</IRI>
    <Literal xml:lang="FR">Adoption d'une perspective globale, exempte de parti pris, visant l'universalité des argumentations.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#universality</IRI>
    <Literal xml:lang="EN">Adoption of a global perspective free of particular bias, aiming at the universality of arguments.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#universality</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Universalism</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#universality</IRI>
    <Literal xml:lang="FR">https://www.lecercledespsy.com/quest-ce-que-la-pensee-universelle/</Literal>
  </AnnotationAssertion>
