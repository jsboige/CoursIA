    <IRI>https://www.argumentum.games/argumentum_virtues.owl#correctSyntheticReasoning</IRI>
    <Literal xml:lang="EN">Correct synthetic reasoning</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#correctSyntheticReasoning</IRI>
    <Literal xml:lang="FR">Raisonnement qui recompose un tout à partir de ses parties pour en saisir la structure et le sens global.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#correctSyntheticReasoning</IRI>
    <Literal xml:lang="EN">A reasoning method that makes it possible to understand a whole by reconstructing it from its parts.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
