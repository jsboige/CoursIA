    <Literal xml:lang="FR">Présentation de raisons claires et convaincantes pour étayer une proposition ou un argument.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#explicitJustifications</IRI>
    <Literal xml:lang="EN">Presentation of explanatory and convincing justifications to support a proposal or an argument.</Literal>
  </AnnotationAssertion>
