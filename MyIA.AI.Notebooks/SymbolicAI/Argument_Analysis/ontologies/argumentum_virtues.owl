    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validArgumentScheme</IRI>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validFormalLogic</IRI>
    <Literal xml:lang="FR">Validité formelle</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validFormalLogic</IRI>
    <Literal xml:lang="EN">Valid formal logic</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validFormalLogic</IRI>
    <Literal xml:lang="FR">Évaluer un raisonnement selon sa forme logique, indépendamment de son contenu.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validFormalLogic</IRI>
    <Literal xml:lang="EN">Formal logic is a means of analyzing reasoning in order to determine its validity and conclusiveness.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validFormalLogic</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Formal_logic</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validFormalLogic</IRI>
    <Literal xml:lang="FR">https://fr.wikipedia.org/wiki/Logique_formelle</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
