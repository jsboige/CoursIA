    <IRI>https://www.argumentum.games/argumentum_virtues.owl#realisticDemands</IRI>
    <Literal xml:lang="FR">Transparence sur les aspects importants, afin d’offrir à l’adversaire un cadre argumentatif réaliste.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#realisticDemands</IRI>
    <Literal xml:lang="EN">Transparency in highlighting important aspects, providing the opponent with a realistic argumentative framework.</Literal>
  </AnnotationAssertion>
