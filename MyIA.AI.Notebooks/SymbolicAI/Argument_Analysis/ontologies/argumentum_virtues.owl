    <IRI>https://www.argumentum.games/argumentum_virtues.owl#rigorousConstructionOfStatements</IRI>
    <Literal xml:lang="EN">Rigorous construction of statements</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
