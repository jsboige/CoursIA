  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#validReasoning</IRI>
    <Literal xml:lang="FR">La conclusion découle-t-elle réellement des prémisses acceptées selon une règle d’inférence valide ?</Literal>
  </AnnotationAssertion>
