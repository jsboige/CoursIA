    <Literal xml:lang="FR">Niveau de preuve approprié</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateLevelOfProof</IRI>
    <Literal xml:lang="EN">Appropriate level of proof</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateLevelOfProof</IRI>
    <Literal xml:lang="FR">Exigence de critères clairs, mesurables et équitables pour évaluer la réussite d’une argumentation.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateLevelOfProof</IRI>
    <Literal xml:lang="EN">The expected objective for the opponent must be attainable and fair, with measurable, clear and well-defined criteria for assessing success.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#appropriateLevelOfProof</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Evidence</Literal>
  </AnnotationAssertion>
