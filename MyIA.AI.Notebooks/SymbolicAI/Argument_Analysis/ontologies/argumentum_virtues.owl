    <IRI>https://www.argumentum.games/argumentum_virtues.owl#questForConsensus</IRI>
    <Literal xml:lang="FR">Quête de consensus</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#questForConsensus</IRI>
    <Literal xml:lang="EN">Quest for consensus</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#questForConsensus</IRI>
    <Literal xml:lang="FR">Recherche de solutions mutuellement acceptables, sans imposer un point de vue particulier.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#questForConsensus</IRI>
    <Literal xml:lang="EN">Commitment to the discovery of mutually acceptable resolutions without imposing a specific point of view.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#questForConsensus</IRI>
    <Literal xml:lang="EN">https://en.wikipedia.org/wiki/Consensus</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#questForConsensus</IRI>
