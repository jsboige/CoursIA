    <Literal xml:lang="FR">Langage respectueux</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectfulLanguage</IRI>
    <Literal xml:lang="EN">Respectful language</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectfulLanguage</IRI>
    <Literal xml:lang="FR">Employer un langage clair, respectueux et accessible à l’ensemble de l’auditoire, adapté au sujet traité.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectfulLanguage</IRI>
    <Literal xml:lang="EN">Use of unambiguous language free of prejudice, easily accessible to all listeners, and suited to the subject being addressed.</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#seeAlso" />
    <IRI>https://www.argumentum.games/argumentum_virtues.owl#respectfulLanguage</IRI>
