<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://example.org/university"
         xmlns="http://example.org/university#">

<owl:Ontology rdf:about="http://example.org/university"/>

<owl:ObjectProperty rdf:about="#enrolledIn">
  <rdfs:domain rdf:resource="#Student"/>
  <rdfs:range rdf:resource="#Course"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#teaches">
  <rdfs:domain rdf:resource="#Professor"/>
  <rdfs:range rdf:resource="#Course"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#memberOf">
  <rdfs:domain rdf:resource="#Person"/>
  <rdfs:range rdf:resource="#Department"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#advisedBy">
  <rdfs:domain rdf:resource="#GraduateStudent"/>
  <rdfs:range rdf:resource="#Professor"/>
</owl:ObjectProperty>

<owl:DatatypeProperty rdf:about="#fullName">
  <rdfs:domain rdf:resource="#Person"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#credits">
  <rdfs:domain rdf:resource="#Course"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:Class rdf:about="#Person">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Student">
  <rdfs:subClassOf rdf:resource="#Person"/>
</owl:Class>

<owl:Class rdf:about="#Professor">
  <rdfs:subClassOf rdf:resource="#Person"/>
  <owl:disjointWith rdf:resource="#Student"/>
</owl:Class>

<owl:Class rdf:about="#GraduateStudent">
  <rdfs:subClassOf rdf:resource="#Student"/>
</owl:Class>

<owl:Class rdf:about="#Course">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Department">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:NamedIndividual rdf:about="#prof_dupont">
  <rdf:type rdf:resource="#Professor"/>
  <teaches rdf:resource="#course_ia"/>
  <teaches rdf:resource="#course_web_sem"/>
  <memberOf rdf:resource="#dept_info"/>
  <fullName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Marie Dupont</fullName>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#etud_martin">
  <rdf:type rdf:resource="#GraduateStudent"/>
  <enrolledIn rdf:resource="#course_ia"/>
  <enrolledIn rdf:resource="#course_web_sem"/>
  <advisedBy rdf:resource="#prof_dupont"/>
  <memberOf rdf:resource="#dept_info"/>
  <fullName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pierre Martin</fullName>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#etud_bernard">
  <rdf:type rdf:resource="#Student"/>
  <enrolledIn rdf:resource="#course_web_sem"/>
  <fullName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sophie Bernard</fullName>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#dept_info">
  <rdf:type rdf:resource="#Department"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Departement Informatique</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#course_ia">
  <rdf:type rdf:resource="#Course"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Intelligence Artificielle</rdfs:label>
  <credits rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">6</credits>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#course_web_sem">
  <rdf:type rdf:resource="#Course"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Web Semantique</rdfs:label>
  <credits rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</credits>
</owl:NamedIndividual>


</rdf:RDF>
