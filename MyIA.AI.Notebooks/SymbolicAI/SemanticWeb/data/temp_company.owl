<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://example.org/company.owl"
         xmlns="http://example.org/company.owl#">

<owl:Ontology rdf:about="http://example.org/company.owl"/>

<owl:ObjectProperty rdf:about="#works_in">
  <rdfs:domain rdf:resource="#Person"/>
  <rdfs:range rdf:resource="#Department"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#manages">
  <rdfs:domain rdf:resource="#Person"/>
  <rdfs:range rdf:resource="#Department"/>
</owl:ObjectProperty>

<owl:Class rdf:about="#Person">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Department">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Manager">
  <rdfs:subClassOf rdf:resource="#Person"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Person"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#manages"/>
          <owl:someValuesFrom rdf:resource="#Department"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="#Employee">
  <rdfs:subClassOf rdf:resource="#Person"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Person"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#works_in"/>
          <owl:someValuesFrom rdf:resource="#Department"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:NamedIndividual rdf:about="#IT">
  <rdf:type rdf:resource="#Department"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#HR">
  <rdf:type rdf:resource="#Department"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Bob">
  <rdf:type rdf:resource="#Person"/>
  <works_in rdf:resource="#IT"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Alice">
  <rdf:type rdf:resource="#Person"/>
  <works_in rdf:resource="#HR"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Charlie">
  <rdf:type rdf:resource="#Person"/>
  <manages rdf:resource="#IT"/>
  <works_in rdf:resource="#IT"/>
</owl:NamedIndividual>


</rdf:RDF>
