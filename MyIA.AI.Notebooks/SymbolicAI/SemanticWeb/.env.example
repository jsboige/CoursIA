# SemanticWeb series - API keys configuration
# Copy this file to .env and fill in the values

# Required for SW-13 (GraphRAG) only
OPENAI_API_KEY=sk-...
# Or alternatively:
ANTHROPIC_API_KEY=sk-ant-...
# Or Google Gemini (used by SW-12 GraphRAG via the OpenAI-compatible endpoint).
# SW-12 uses gemini-2.5-flash-lite by default (cheapest model).
# Tip: some student offers include free Gemini API credits.
GEMINI_API_KEY=...

# Optional: batch mode for non-interactive execution
BATCH_MODE=false
