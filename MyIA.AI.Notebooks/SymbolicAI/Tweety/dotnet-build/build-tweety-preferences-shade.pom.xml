<?xml version="1.0" encoding="UTF-8"?>
<!-- Standalone shade aggregator for the preferences module (org.tweetyproject.preferences):
     bundles preferences + transitive deps from local m2 into one coherent fat-jar.
     Phase 0.5 (po-2025 user) confirmed the preferences module SUCCEEDS at release=11 with
     zero source patches (no Java 12+ switch expressions; module is standalone, no Dung
     cascade). The IKVM 8.15 / IKVM0101 risk surface is therefore narrow: only the
     preferences module's own classes need to be Java-11-clean (major version 55),
     which they are per upstream.
     Reproduction of the shade pattern from MLN (#5209) and PL (#4711): single Maven
     shade aggregator with junit exclusions. Preferences Tw-9 Csharp PR continues EPIC
     #4667 beyond Tw-3 (DL/CL/QBF/ML all complete).
     Concepts: preference orders (StrictPreferenceOrder, NaivePreferenceOrder),
     aggregation (Borda, Plurality, Scoring, Condorcet, Copeland), link to argumentation
     (StableMarriage-based tie-breaking).

     CRITICAL: maven-compiler-plugin MUST be pinned to release=11 (major version 55)
     because IKVM 8.15 silently drops classes with major version > 55 (Java 12+
     bytecode). Without this pin, the JDK 17 default target produces major version 59
     (Java 15) bytecode that IKVM0101 will reject wholesale. Verified 2026-07-03 by
     cycle-13 smoke probe (C.19 PR cycle 13: 0/9 classes exposed despite DLL building). -->
<project xmlns="http://maven.apache.org/POM/4.0.0">
  <modelVersion>4.0.0</modelVersion>
  <groupId>local</groupId>
  <artifactId>tweety-preferences-shade</artifactId>
  <version>1.30</version>
  <packaging>jar</packaging>
  <name>Tweety preferences shaded fat-jar (IKVM target)</name>

  <dependencies>
    <dependency>
      <groupId>org.tweetyproject</groupId>
      <artifactId>preferences</artifactId>
      <version>1.30-SNAPSHOT</version>
      <exclusions>
        <exclusion>
          <groupId>junit</groupId>
          <artifactId>junit</artifactId>
        </exclusion>
        <exclusion>
          <groupId>org.junit.jupiter</groupId>
          <artifactId>junit-jupiter</artifactId>
        </exclusion>
        <exclusion>
          <groupId>org.junit</groupId>
          <artifactId>junit-bom</artifactId>
        </exclusion>
        <!-- Exclude commons 1.30 (Maven Central, major 59 / Java 15 bytecode, IKVM0101 drops it) -->
        <exclusion>
          <groupId>org.tweetyproject</groupId>
          <artifactId>commons</artifactId>
        </exclusion>
        <exclusion>
          <groupId>org.tweetyproject</groupId>
          <artifactId>plugin</artifactId>
        </exclusion>
        <exclusion>
          <groupId>org.tweetyproject</groupId>
          <artifactId>math</artifactId>
        </exclusion>
      </exclusions>
    </dependency>
    <!-- Re-inject commons/plugin/math in 1.30-SNAPSHOT (locally built, major 52 / Java 8, IKVM-compatible) -->
    <dependency>
      <groupId>org.tweetyproject</groupId>
      <artifactId>commons</artifactId>
      <version>1.30-SNAPSHOT</version>
    </dependency>
    <dependency>
      <groupId>org.tweetyproject</groupId>
      <artifactId>plugin</artifactId>
      <version>1.30-SNAPSHOT</version>
    </dependency>
    <dependency>
      <groupId>org.tweetyproject</groupId>
      <artifactId>math</artifactId>
      <version>1.30-SNAPSHOT</version>
    </dependency>
  </dependencies>

  <build>
    <finalName>tweety-preferences-full-1.30</finalName>
    <plugins>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.13.0</version>
        <configuration>
          <source>11</source>
          <target>11</target>
          <release>11</release>
        </configuration>
      </plugin>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.5.3</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals><goal>shade</goal></goals>
            <configuration>
              <createDependencyReducedPom>false</createDependencyReducedPom>
              <shadedArtifactAttached>false</shadedArtifactAttached>
              <transformers>
                <transformer implementation="org.apache.maven.plugins.shade.resource.ServicesResourceTransformer"/>
                <transformer implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer"/>
              </transformers>
              <filters>
                <filter>
                  <artifact>*:*</artifact>
                  <excludes>
                    <exclude>META-INF/*.SF</exclude>
                    <exclude>META-INF/*.DSA</exclude>
                    <exclude>META-INF/*.RSA</exclude>
                    <exclude>module-info.class</exclude>
                  </excludes>
                </filter>
              </filters>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
</project>
