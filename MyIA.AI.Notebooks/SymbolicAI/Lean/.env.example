# Configuration Lean Notebooks
# Copier ce fichier vers .env et renseigner les valeurs

# ============================================================
# Service LLM principal (utilise par Semantic Kernel dans Lean-7/8/9)
# ============================================================

# Choix du provider par defaut
# Valeurs supportees : "OpenAI", "AzureOpenAI", "Anthropic", "OpenRouter", "ZAI", "QwenLocal"
GLOBAL_LLM_SERVICE="ZAI"

# ============================================================
# Anthropic Claude (Sonnet 4.6 recommande pour calibration agents)
# ============================================================

# Cle API Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Modele : claude-sonnet-4-6 (defaut SOTA pour calibration), claude-opus-4-7, claude-haiku-4-5-20251001
ANTHROPIC_CHAT_MODEL_ID="claude-sonnet-4-6"

# ============================================================
# z.ai GLM-5.1 (recommande comme primary pour Lean-9 multi-agent)
# Souscription user generuse, vitesse non critique
# ============================================================

# Cle API z.ai (generer une cle dediee Lean-9, distincte des cles vibe-coding)
# ZAI_API_KEY=...

# Endpoint z.ai (compatible OpenAI Chat Completions)
ZAI_BASE_URL="https://open.bigmodel.cn/api/paas/v4"

# Modele
ZAI_CHAT_MODEL_ID="glm-5.1"

# ============================================================
# Qwen 3.6 35B-A3B local (vLLM sur ai-01, port 5002)
# Utiliser en mode "thinking" pour les agents Search/Tactic peu gourmands
# ============================================================

# Endpoint vLLM local (compatible OpenAI Chat Completions)
QWEN_LOCAL_BASE_URL="http://localhost:5002/v1"

# Bearer token (defini dans la config vLLM ai-01, voir GenAI/.env OPENAI_API_KEY_3)
# QWEN_LOCAL_API_KEY=...

# Modele expose par vLLM
QWEN_LOCAL_CHAT_MODEL_ID="qwen3.5-35b-a3b"

# Mode thinking (laisser le modele raisonner verbalement avant de produire la sortie finale)
QWEN_LOCAL_THINKING_MODE="true"

# ============================================================
# OpenAI (fallback historique)
# ============================================================

# OPENAI_ENDPOINT_NAME="OpenAI"
# OPENAI_API_KEY=sk-...
# OPENAI_CHAT_MODEL_ID="gpt-5.2"
# OPENAI_BASE_URL=""

# ============================================================
# OpenRouter (multi-modeles)
# ============================================================

# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
# OPENROUTER_CHAT_MODEL_ID="anthropic/claude-sonnet-4"
# OPENROUTER_APP_NAME="CoursIA-Lean"

# ============================================================
# Configuration multi-agent Lean-9 (par-agent, optionnel)
# ============================================================

# Surcharge le modele par-agent. Si non defini, fallback sur GLOBAL_LLM_SERVICE.
# Valeurs : meme syntaxe que GLOBAL_LLM_SERVICE
# COORDINATOR_MODEL="ZAI"
# SEARCH_MODEL="QwenLocal"
# TACTIC_MODEL="ZAI"
# VERIFIER_MODEL="QwenLocal"
# CRITIC_MODEL="Anthropic"

# ============================================================
# Configuration Lean
# ============================================================

# Version de Lean a utiliser (stable, nightly, ou version specifique)
LEAN_VERSION=stable

# Chemin vers elan (si non standard)
# ELAN_HOME=/custom/path/to/.elan

# Backend par defaut du LeanRunner ("subprocess", "wsl", "auto")
# Sur Windows, "auto" prefere WSL si dispo. Sinon "subprocess" Windows-natif.
LEAN_RUNNER_BACKEND="auto"

# Repertoire projet Lean par defaut pour la verification (avec .lake cache)
# Si defini, LeanRunner.run() utilise `lake env lean` au lieu de `lean` direct,
# ce qui permet la reutilisation du cache Mathlib (sinon rebuild a chaque appel).
# Chemins absolus ou relatifs au repo CoursIA root.
# Exemples :
#   MyIA.AI.Notebooks/SymbolicAI/Lean/mathlib_examples           (Lean v4.27, Mathlib basique)
#   MyIA.AI.Notebooks/GameTheory/cooperative_games_lean          (Lean v4.28.0-rc1, Shapley/STV)
#   MyIA.AI.Notebooks/GameTheory/social_choice_lean              (Lean v4.29.1, Arrow/Sen/Voting)
LEAN_PROJECT_DIR="MyIA.AI.Notebooks/SymbolicAI/Lean/mathlib_examples"

# ============================================================
# Configuration boucle de preuve (Lean-8/9)
# ============================================================

# Modele LLM a utiliser pour la generation de preuves (legacy, voir GLOBAL_LLM_SERVICE)
LLM_MODEL="glm-5.1"

# Nombre maximum d'iterations pour les boucles de preuve
MAX_PROOF_ITERATIONS=15

# Timeout pour la verification Lean (en secondes). 60s pour proofs simples,
# 180s+ recommande pour Mathlib-dependent (premier appel charge le cache).
LEAN_TIMEOUT=120

# Repertoire ou logger les sessions JSON multi-agent (Lean-9)
SESSION_LOG_DIR="logs/multi_agent_sessions"

# ============================================================
# Mode batch pour execution automatisee
# ============================================================

# Active le mode batch (skip les parties interactives)
# Mettre a "true" pour Papermill/MCP, "false" pour mode interactif
BATCH_MODE="false"

# Texte personnalise pour tests en mode batch
# BATCH_TEXT="Texte de test..."

# ============================================================
# Configuration GitHub (pour LeanDojo - Lean-10 uniquement)
# ============================================================

# Token GitHub pour l'API (requis pour LeanDojo)
# Generer sur: https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_...
# GITHUB_ACCESS_TOKEN=ghp_...
