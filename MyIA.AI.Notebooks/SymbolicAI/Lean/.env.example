# Configuration Lean Notebooks
# Copier ce fichier vers .env et renseigner les valeurs

# ============================================================
# Configuration Semantic Kernel (pour Lean-7, Lean-8)
# ============================================================

# Service LLM a utiliser (OpenAI, AzureOpenAI, Anthropic)
GLOBAL_LLM_SERVICE="OpenAI"

# Nom du endpoint OpenAI (pour Semantic Kernel)
OPENAI_ENDPOINT_NAME="OpenAI"

# Cle API OpenAI
OPENAI_API_KEY=sk-...

# Modele de chat OpenAI (gpt-5.2, gpt-5-mini, etc.)
OPENAI_CHAT_MODEL_ID="gpt-5.2"

# URL de base alternative (pour z.ai proxy ou autre)
# OPENAI_BASE_URL="https://api.z.ai/v1"

# URL de base OpenAI (laisser vide pour URL par defaut)
# OPENAI_BASE_URL=""

# ============================================================
# Configuration Anthropic (alternative a OpenAI)
# ============================================================

# Cle API Anthropic (pour Claude)
# ANTHROPIC_API_KEY=sk-ant-...

# Modele Claude (claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5)
# ANTHROPIC_CHAT_MODEL_ID="claude-sonnet-4-6"

# ============================================================
# Configuration z.ai (GLM-5.1, GLM-4.7)
# ============================================================

# Cle API z.ai
# ZAI_API_KEY=your-zai-key

# URL de base z.ai (OpenAI-compatible endpoint)
# ZAI_BASE_URL="https://api.z.ai/api/coding/paas/v4"

# Modele principal z.ai (GLM-5.1 pour raisonnement avance)
# ZAI_CHAT_MODEL_ID="glm-5.1"

# Modele rapide z.ai (GLM-4.7 pour tactiques simples)
# ZAI_FAST_MODEL_ID="glm-4.7"

# ============================================================
# Configuration modele local (Qwen 3.6-35B-A3B via vLLM)
# ============================================================

# URL du serveur local (text-generation-webui)
# LOCAL_LLM_BASE_URL="https://api.medium.text-generation-webui.myia.io/v1"

# Cle API locale
# LOCAL_LLM_API_KEY="your-key"

# Modele local
# LOCAL_LLM_MODEL_ID="qwen3.6-35b-a3b"

# ============================================================
# Configuration OpenRouter (multi-modeles)
# ============================================================

# Cle API OpenRouter
# OPENROUTER_API_KEY=sk-or-...

# URL de base OpenRouter
# OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# Modele OpenRouter (format: provider/model)
# OPENROUTER_CHAT_MODEL_ID="anthropic/claude-sonnet-4"

# Nom de l'application (pour tracking)
# OPENROUTER_APP_NAME="CoursIA-Lean"

# ============================================================
# Configuration Lean
# ============================================================

# Version de Lean a utiliser (stable, nightly, ou version specifique)
LEAN_VERSION=stable

# Chemin vers elan (si non standard)
# ELAN_HOME=/custom/path/to/.elan

# Chemin vers le projet Lake (requis pour lake env lean)
# Windows:
LEAN_PROJECT_DIR="C:\\dev\\CoursIA\\MyIA.AI.Notebooks\\GameTheory\\cooperative_games_lean"
# WSL:
# LEAN_PROJECT_DIR="/mnt/c/dev/CoursIA/MyIA.AI.Notebooks/GameTheory/cooperative_games_lean"

# ============================================================
# Configuration des agents (Lean-9 Multi-Agents)
# ============================================================

# Provider LLM principal (openai, anthropic, zai, local, openrouter)
GLOBAL_LLM_SERVICE="zai"

# Modele LLM pour la generation de preuves (agents Search, Tactic)
LLM_MODEL="glm-5.1"

# Modele LLM pour la verification rapide (agent Verifier)
LLM_FAST_MODEL="glm-4.7"

# Modele LLM pour le coordinateur et le critique (agents Coordinator, Critic)
LLM_REASONING_MODEL="glm-5.1"

# Nombre maximum d'iterations pour les boucles de preuve
MAX_PROOF_ITERATIONS=10

# Timeout pour la verification Lean (en secondes)
LEAN_TIMEOUT=60

# ============================================================
# Mode batch pour execution automatisee
# ============================================================

# Active le mode batch (skip les parties interactives)
# Mettre a "true" pour Papermill/MCP, "false" pour mode interactif
BATCH_MODE="false"

# Texte personnalise pour tests en mode batch
# BATCH_TEXT="Texte de test..."

# ============================================================
# Configuration GitHub (pour LeanDojo)
# ============================================================

# Token GitHub pour l'API (requis pour LeanDojo)
# Generer sur: https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_...

# Alternative: GITHUB_ACCESS_TOKEN (nom utilise par LeanDojo)
# GITHUB_ACCESS_TOKEN=ghp_...
