@prefix ex: <http://example.org/pizza#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:PizzaOntology a owl:Ontology .

ex:deepBase a ex:DeepPanBase .

ex:margherita a ex:VegetarianPizza ;
    ex:hasTopping ex:mozzarella,
        ex:tomato .

ex:myPizza a ex:Pizza .

ex:pepperoni a ex:NonVegetarianPizza ;
    ex:hasTopping ex:ham,
        ex:mozzarella .

ex:thinBase a ex:ThinAndCrispyBase .

ex:CheeseTopping a owl:Class ;
    rdfs:subClassOf ex:PizzaTopping,
        ex:VegetarianTopping .

ex:DeepPanBase a owl:Class ;
    rdfs:subClassOf ex:PizzaBase .

ex:MeatTopping a owl:Class ;
    rdfs:subClassOf ex:PizzaTopping .

ex:NonVegetarianPizza a owl:Class ;
    rdfs:subClassOf ex:Pizza .

ex:ThinAndCrispyBase a owl:Class ;
    rdfs:subClassOf ex:PizzaBase .

ex:VegetarianPizza a owl:Class ;
    rdfs:subClassOf ex:Pizza,
        ex:VegetarianRestriction ;
    owl:equivalentClass ex:VegetarianPizzaDef .

ex:VegetarianPizzaDef a owl:Class .

ex:VegetarianRestriction a owl:Restriction ;
    owl:allValuesFrom ex:VegetarianTopping ;
    owl:onProperty ex:hasTopping .

ex:ham a ex:MeatTopping .

ex:hasTopping a owl:ObjectProperty ;
    rdfs:domain ex:Pizza ;
    rdfs:range ex:PizzaTopping .

ex:tomato a ex:VegetarianTopping .

ex:PizzaBase a owl:Class .

ex:mozzarella a ex:CheeseTopping .

ex:VegetarianTopping a owl:Class ;
    rdfs:subClassOf ex:PizzaTopping .

ex:Pizza a owl:Class .

ex:PizzaTopping a owl:Class .

